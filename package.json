{
  "name": "mrtpvrest",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:report": "playwright show-report tests/e2e/results/html-report",
    "test:e2e:ui": "playwright test --ui --config=tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "dotenv": "^16.4.4",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
