pnpm-version=9.15.0

# Hoist webpack loaders y plugins al root node_modules para que herramientas
# como next-pwa (que llaman require('babel-loader') desde un contexto webpack
# no-pnpm-aware) puedan resolverlos en monorepos pnpm + Vercel.
public-hoist-pattern[]=*babel-loader*
public-hoist-pattern[]=*webpack*
public-hoist-pattern[]=*workbox*
public-hoist-pattern[]=@babel/*

# Workspaces: enlaces directos para que Next.js + Turbo resuelvan
# dependencias locales sin ambigüedad
shared-workspace-lockfile=true
link-workspace-packages=true
