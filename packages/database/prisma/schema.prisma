// ─────────────────────────────────────────────────────────────────────────────
// schema.prisma — Restaurante Pedidos Online (SaaS Pro Multi-tenant)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT (cuenta que se registra — dueño de la marca)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  ownerEmail     String
  logoUrl        String?
  primaryColor   String?
  onboardingStep Int      @default(0)
  onboardingDone Boolean  @default(false)

  subscription   Subscription?
  restaurants    Restaurant[]
  users          User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLANES (catálogo, gestionado por super-admin)
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique       // "BASIC" | "PRO" | "UNLIMITED"
  displayName   String                 // "Básico" | "Pro" | "Ilimitado"
  price         Float                  // precio mensual en USD
  trialDays     Int      @default(15)
  maxLocations  Int      @default(1)
  maxEmployees  Int      @default(5)
  hasKDS        Boolean  @default(false)
  hasLoyalty    Boolean  @default(false)
  hasInventory  Boolean  @default(false)
  hasReports    Boolean  @default(false)
  hasAPIAccess  Boolean  @default(false)
  isActive      Boolean  @default(true)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUSCRIPCIÓN (instancia viva Restaurant + Plan)
// ─────────────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String?            @unique
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])

  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  pausedAt           DateTime?

  // Precio al momento de contratar (no muta si el Plan cambia de precio)
  priceSnapshot      Float

  // Gateway — MANUAL por ahora, Stripe/MP después
  externalId         String?
  paymentGateway     String?            // "MANUAL" | "STRIPE" | "MERCADOPAGO"

  invoices           Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// FACTURAS (auditoría y cálculo de MRR)
// ─────────────────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount         Float
  currency       String        @default("USD")
  status         InvoiceStatus @default(PENDING)
  paidAt         DateTime?
  periodStart    DateTime
  periodEnd      DateTime
  externalId     String?       // charge ID del gateway cuando lo haya

  createdAt DateTime @default(now())

  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURACIÓN GLOBAL DEL SAAS (MRTPVREST)
// ─────────────────────────────────────────────────────────────────────────────

model GlobalConfig {
  id                String   @id @default("saas-config")
  basicPlanPrice    Float    @default(29)
  proPlanPrice      Float    @default(59)
  unlimitedPlanPrice Float   @default(99)
  trialDays         Int      @default(15)
  currency          String   @default("USD")
  supportEmail      String?
  updatedAt         DateTime @updatedAt

  @@map("global_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENTIDAD MAESTRA: RESTAURANTE (LA MARCA)
// ─────────────────────────────────────────────────────────────────────────────

model Restaurant {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  slug        String   @unique
  name        String
  domain      String?  @unique
  isActive    Boolean  @default(true)
  logoUrl     String?  // Logo personalizado del cliente

  // Configuración Global
  config        RestaurantConfig?

  // Relaciones Globales (Marca)
  locations         Location[]
  users             User[]
  categories        Category[]
  menuItems         MenuItem[]
  variantTemplates  VariantTemplate[]
  loyaltyAccounts   LoyaltyAccount[]
  coupons           Coupon[]
  integrations      IntegrationConfig[]
  orders            Order[]
  suppliers         Supplier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("restaurants")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUCURSAL (LOCATION) - EL LUGAR FÍSICO
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name         String
  slug         String
  address      String?
  phone        String?
  isActive     Boolean    @default(true)

  // Configuración de Ticket por sucursal
  ticketConfig TicketConfig?

  // Operación Local
  orders            Order[]
  employees         Employee[]
  printers          Printer[]
  ingredients       Ingredient[]
  banners           Banner[]
  waiters           Waiter[]
  cashShifts        CashShift[]
  externalOrders    ExternalOrder[]
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, slug])
  @@map("locations")
}

// ─────────────────────────────────────────────────────────────────────────────
// USUARIOS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  KITCHEN
  SUPER_ADMIN
}

model User {
  id           String    @id @default(cuid())
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  name         String
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         Role      @default(CUSTOMER)
  avatarUrl    String?
  isActive     Boolean   @default(true)

  addresses     Address[]
  orders        Order[]
  loyalty       LoyaltyAccount?
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String  @default("Casa")
  street       String
  extNumber    String
  intNumber    String?
  neighborhood String
  city         String
  state        String  @default("México")
  zipCode      String
  references   String?
  lat          Float?
  lng          Float?
  isDefault    Boolean @default(false)
  orders       Order[]

  createdAt DateTime @default(now())

  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENÚ GLOBAL
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  imageUrl     String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  loyverseId   String?    @unique
  items        MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model MenuItem {
  id              String               @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category             @relation(fields: [categoryId], references: [id])

  name            String
  description     String?
  imageUrl        String?
  price           Float
  isAvailable     Boolean              @default(true)
  isPopular       Boolean              @default(false)
  hasVariants     Boolean              @default(false)
  preparationTime Int                  @default(15)
  loyverseId      String?              @unique

  modifierGroups  ModifierGroup[]
  orderItems      OrderItem[]
  variants        MenuItemVariant[]
  complements     MenuItemComplement[]
  recipeItems     RecipeItem[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("menu_items")
}

model ModifierGroup {
  id          String     @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String
  required    Boolean    @default(false)
  multiSelect Boolean    @default(false)
  modifiers   Modifier[]

  @@map("modifier_groups")
}

model Modifier {
  id                 String              @id @default(cuid())
  groupId            String
  group              ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name               String
  priceAdd           Float               @default(0)
  isDefault          Boolean             @default(false)
  orderItemModifiers OrderItemModifier[]

  @@map("modifiers")
}

// ─────────────────────────────────────────────────────────────────────────────
// PEDIDOS (LOCALES)
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD_PRESENT
  TRANSFER
  COURTESY
  PENDING
  CARD
  OXXO
  SPEI
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id            String   @id @default(cuid())
  restaurantId  String
  locationId    String?
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  location      Location?  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  orderNumber   String   @unique
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  addressId     String?
  address       Address? @relation(fields: [addressId], references: [id])

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  subtotal    Float
  deliveryFee Float @default(0)
  discount    Float @default(0)
  total       Float

  pointsEarned Int @default(0)
  pointsUsed   Int @default(0)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  notes String?

  orderType        String    @default("DELIVERY")
  tableNumber      Int?
  source           String    @default("ONLINE")
  deliveryDriverId String?
  deliveryAddress  String?
  customerName     String?
  customerPhone    String?
  paidAt           DateTime?

  cashCollected    Boolean   @default(false)
  cashCollectedAt  DateTime?
  cashCollectedBy  String?

  conektaOrderId  String?
  conektaChargeId String?
  loyverseReceiptId String?
  estimatedMinutes Int?

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id         String              @id @default(cuid())
  orderId    String
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id])
  name       String
  price      Float
  quantity   Int
  subtotal   Float
  notes      String?
  modifiers  OrderItemModifier[]

  @@map("order_items")
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String
  modifier    Modifier  @relation(fields: [modifierId], references: [id])
  name        String
  priceAdd    Float

  @@map("order_item_modifiers")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@map("order_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEALTAD & CUPONES
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyAccount {
  id           String               @id @default(cuid())
  restaurantId String
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       String               @unique
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  points       Int                  @default(0)
  totalEarned  Int                  @default(0)
  tier         LoyaltyTier          @default(BRONZE)
  qrCode       String               @unique
  transactions LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loyalty_accounts")
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
}

enum LoyaltyTxType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        LoyaltyTxType
  points      Int
  description String
  orderId     String?
  createdAt   DateTime       @default(now())

  @@map("loyalty_transactions")
}

model Coupon {
  id             String       @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  code           String       @unique
  description    String
  discountType   DiscountType
  discountValue  Float
  minOrderAmount Float        @default(0)
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  orders         Order[]

  createdAt DateTime @default(now())

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURACIÓN
// ─────────────────────────────────────────────────────────────────────────────

model RestaurantConfig {
  id                String  @id @default(cuid())
  restaurantId      String  @unique
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  phone             String?
  whatsappNumber    String?
  address           String?
  deliveryFee       Float   @default(0)
  freeDeliveryFrom  Float?
  minOrderAmount    Float   @default(0)
  estimatedDelivery Int     @default(40)
  isOpen            Boolean @default(true)
  closedMessage     String?

  pointsPerTen     Int   @default(1)
  pointsValuePesos Float @default(0.10)

  updatedAt DateTime @updatedAt

  @@map("restaurant_config")
}

model TicketConfig {
  id            String   @id @default(cuid())
  locationId    String?  @unique
  location      Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  businessName  String  @default("Master Burger's")
  header        String  @default("Master Burger's")
  subheader     String  @default("A chuparse los dedos")
  footer        String  @default("Gracias por su preferencia")
  showLogo      Boolean @default(true)
  showAddress   Boolean @default(true)
  address       String  @default("")
  phone         String  @default("")
  showPoints    Boolean @default(true)
  showTip       Boolean @default(true)
  tipSuggestions String @default("[10,15,20]")
  kitchenHeader String  @default("*** COCINA ***")
  kitchenLayout String?
  adminPin      String  @default("0000")
  kitchenShowCustomer Boolean @default(true)
  kitchenShowTable    Boolean @default(true)
  kitchenShowType     Boolean @default(true)
  kitchenShowTime     Boolean @default(true)
  
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// OTROS (LOCALES)
// ─────────────────────────────────────────────────────────────────────────────

model Printer {
  id           String   @id @default(cuid())
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name         String
  ip           String
  port         Int      @default(9100)
  type         String   @default("KITCHEN")
  isActive     Boolean  @default(true)
  categories   String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Banner {
  id            String    @id @default(cuid())
  locationId    String?
  location      Location?  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  title         String    @default("")
  description   String    @default("")
  imageUrl      String
  linkType      String    @default("NONE")
  linkValue     String    @default("")
  isActive      Boolean   @default(false)
  sortOrder     Int       @default(0)
  scheduleDays  String    @default("[]")
  scheduleStart String    @default("")
  scheduleEnd   String    @default("")
  dateFrom      DateTime?
  dateTo        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Supplier {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name         String
  contact      String       @default("")
  phone        String       @default("")
  email        String       @default("")
  address      String       @default("")
  notes        String       @default("")
  isActive     Boolean      @default(true)
  ingredients  Ingredient[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Ingredient {
  id           String              @id @default(cuid())
  locationId   String?
  location     Location?            @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name         String
  unit         String              @default("pz")
  stock        Float               @default(0)
  minStock     Float               @default(0)
  cost         Float               @default(0)
  supplierId   String?
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  isActive     Boolean             @default(true)
  recipeItems  RecipeItem[]
  movements    InventoryMovement[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model RecipeItem {
  id           String     @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  createdAt    DateTime   @default(now())
}

model InventoryMovement {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  type         String
  quantity     Float
  reason       String     @default("")
  orderId      String?
  createdAt    DateTime   @default(now())
}

model Waiter {
  id           String   @id @default(cuid())
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name         String
  pin          String
  photo        String?
  isActive     Boolean  @default(true)
  tables       String[]
  shifts       WaiterShift[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WaiterShift {
  id        String   @id @default(cuid())
  waiterId  String
  waiter    Waiter   @relation(fields: [waiterId], references: [id])
  startAt   DateTime @default(now())
  endAt     DateTime?
  createdAt DateTime @default(now())
}

model Employee {
  id            String   @id @default(cuid())
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name          String
  photo         String?
  phone         String?
  pin           String   @unique
  role          String   @default("WAITER")
  isActive      Boolean  @default(true)
  tables        String[]
  scheduleStart String?
  scheduleEnd   String?
  scheduleDays  String[]

  canCharge         Boolean @default(false)
  canDiscount       Boolean @default(false)
  canModifyTickets  Boolean @default(false)
  canDeleteTickets  Boolean @default(false)
  canConfigSystem   Boolean @default(false)
  canTakeDelivery   Boolean @default(false)
  canTakeTakeout    Boolean @default(true)

  shifts      EmployeeShift[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmployeeShift {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields:[employeeId], references:[id], onDelete: Cascade)
  startAt     DateTime  @default(now())
  endAt       DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
}

model VariantTemplate {
  id           String                   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant               @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name         String
  options      VariantTemplateOption[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@map("variant_templates")
}

model VariantTemplateOption {
  id         String          @id @default(cuid())
  templateId String
  template   VariantTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  price      Float           @default(0)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())

  @@map("variant_template_options")
}

model CashShift {
  id            String   @id @default(cuid())
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  employeeId    String
  employeeName  String
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  isOpen        Boolean  @default(true)
  openingFloat  Float    @default(0)
  closingFloat  Float?
  notes         String?

  totalCash     Float    @default(0)
  totalCard     Float    @default(0)
  totalTransfer Float    @default(0)
  totalCourtesy Float    @default(0)
  totalTips     Float    @default(0)
  totalExpenses Float    @default(0)
  totalSales    Float    @default(0)
  ordersCount   Int      @default(0)

  expenses      ShiftExpense[]

  @@map("cash_shifts")
}

model ShiftExpense {
  id          String    @id @default(cuid())
  shiftId     String
  shift       CashShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  category    String    @default("OTHER")
  createdAt   DateTime  @default(now())

  @@map("shift_expenses")
}

model IntegrationConfig {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  type         String
  enabled      Boolean  @default(false)
  mode         String   @default("sandbox")
  config       String
  webhook      String?
  lastSync     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, type])
}

model ExternalOrder {
  id           String   @id @default(cuid())
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  platform     String
  externalId   String
  orderId      String?
  rawData      String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
}

model PushSubscription {
  id           String   @id @default(cuid())
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  userId       String?
  orderId      String?
  endpoint     String   @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime @default(now())
}

model MenuItemVariant {
  id          String   @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model MenuItemComplement {
  id          String   @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model DeliveryMessage {
  id         String   @id @default(cuid())
  orderId    String
  fromDriver Boolean  @default(false)
  message    String
  createdAt  DateTime @default(now())
}

model DriverCashMovement {
  id          String   @id @default(cuid())
  driverId    String
  type        String
  category    String
  amount      Float
  description String?
  photoUrl    String?
  orderId     String?
  approved    Boolean  @default(false)
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model DriverCashCut {
  id           String   @id @default(cuid())
  driverId     String
  driverName   String
  totalIncome  Float    @default(0)
  totalExpense Float    @default(0)
  totalReturn  Float    @default(0)
  balance      Float    @default(0)
  movements    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
}

model DriverLocation {
  id         String   @id @default(cuid())
  driverId   String
  orderId    String?
  lat        Float
  lng        Float
  accuracy   Float?
  speed      Float?   // km/h
  heading    Float?   // dirección en grados
  createdAt  DateTime @default(now())
}

model DriverRoute {
  id         String   @id @default(cuid())
  driverId   String
  driverName String
  orderId    String?
  startAt    DateTime @default(now())
  endAt      DateTime?
  originLat  Float
  originLng  Float
  points     Int      @default(0)
  distance   Float    @default(0) // km aproximados
  trigger    String   @default("MANUAL") // MANUAL, ORDER_ASSIGNED
}

model KdsItemStatus {
  id          String   @id @default(cuid())
  orderId     String
  orderItemId String
  station     String   // KITCHEN, BAR, FRYER
  done        Boolean  @default(false)
  doneAt      DateTime?
  createdAt   DateTime @default(now())
}

model KdsMessage {
  id        String   @id @default(cuid())
  orderId   String
  station   String   // estación que envía
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
