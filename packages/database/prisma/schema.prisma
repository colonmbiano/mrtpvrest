// ─────────────────────────────────────────────────────────────────────────────
// schema.prisma — Restaurante Pedidos Online (SaaS Pro Multi-tenant)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT (cuenta que se registra — dueño de la marca)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id             String  @id @default(cuid())
  name           String
  slug           String  @unique
  ownerEmail     String
  logoUrl        String?
  primaryColor   String?
  onboardingStep Int     @default(0)
  onboardingDone Boolean @default(false)
  businessType   String? // RESTAURANT | GROCERY | BUTCHER | POULTRY | OTHER
  isOnboarded    Boolean @default(false)
  activeModules  Json    @default("[]")

  // Cuentas DEMO creadas desde el panel SaaS (pantalla /demos) para enseñar el
  // producto a un prospecto con SU menú y SU banner. Son tenants reales y
  // funcionales (login, TPV, tienda) pero se etiquetan para poder filtrarlas
  // fuera de las métricas de clientes y purgarlas al vencer. `demoExpiresAt`
  // marca cuándo caduca la demostración (informativo; la baja la decide el
  // operador o un cron externo).
  isDemo        Boolean   @default(false)
  demoExpiresAt DateTime?

  // SaaS Modules Flags
  hasInventory Boolean @default(false)
  hasDelivery  Boolean @default(false)
  hasWebStore  Boolean @default(false)

  enabledModules String[] @default([])

  // Storefront & Contact
  whatsappNumber String?
  themeConfig    Json? // { theme: "STREET_FOOD", primaryColor: "#000000" }

  // Stripe customer (B2B SaaS billing) — reusado entre checkouts y portal
  stripeCustomerId String? @unique

  emailVerifiedAt         DateTime?
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?
  welcomeEmailSent        Boolean   @default(false)

  subscription Subscription?
  restaurants  Restaurant[]
  users        User[]
  vehicles     Vehicle[]
  rides        Ride[]
  expenses     Expense[]
  devices      Device[]
  promos       Promo[]
  tenantModules TenantModule[]

  adminOnboardingTasks AdminOnboardingTask[]
  adminClientNotes     AdminClientNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT MODULES — fuente de verdad canónica de los módulos por tenant.
//
// Reemplaza la representación dispersa anterior (enabledModules String[] +
// flags booleanos hasInventory/hasDelivery/hasWebStore + activeModules Json),
// que vivía en distintos campos leídos por distintas vistas del panel SaaS.
// Una fila por (tenantId, moduleKey). `enabled` indica si está activo;
// `requiresPlan` marca módulos premium (gated por plan) vs flags libres.
//
// Durante la migración los campos legacy del Tenant se mantienen sincronizados
// (dual-write en el backend) para no romper el gating en runtime.
// ─────────────────────────────────────────────────────────────────────────────

model TenantModule {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleKey    String // inventory | delivery | webstore | kiosk | loyalty | kds | reports | finance
  enabled      Boolean  @default(false)
  requiresPlan Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@map("tenant_modules")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROMOS — publicidad gestionada desde admin para la pantalla de cliente del TPV
// ─────────────────────────────────────────────────────────────────────────────

model Promo {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imageUrl  String
  title     String?
  subtitle  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PLANES (catálogo, gestionado por super-admin)
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id           String  @id @default(cuid())
  name         String  @unique // "BASIC" | "PRO" | "UNLIMITED"
  displayName  String // "Básico" | "Pro" | "Ilimitado"
  price        Float // precio mensual en MXN
  trialDays    Int     @default(15)
  maxLocations Int     @default(1)
  maxEmployees Int     @default(5)
  hasKDS       Boolean @default(false)
  hasLoyalty   Boolean @default(false)
  hasInventory Boolean @default(false)
  hasReports   Boolean @default(false)
  hasAPIAccess Boolean @default(false)
  isActive     Boolean @default(true)

  allowedModules String[] @default([])

  // Stripe Price ID (price_xxx) — product/price creados en el Stripe Dashboard
  stripePriceId String? @unique

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUSCRIPCIÓN (instancia viva Restaurant + Plan)
// ─────────────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

model Subscription {
  id       String  @id @default(cuid())
  tenantId String? @unique
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId   String
  plan     Plan    @relation(fields: [planId], references: [id])

  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  pausedAt           DateTime?

  // Precio al momento de contratar (no muta si el Plan cambia de precio)
  priceSnapshot Float

  // Gateway — MANUAL por ahora, Stripe/MP después
  externalId     String? @unique // id de la suscripción en el gateway; UNIQUE = idempotencia de webhooks a nivel BD
  paymentGateway String? // "MANUAL" | "STRIPE" | "MERCADOPAGO"

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// FACTURAS (auditoría y cálculo de MRR)
// ─────────────────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount      Float
  currency    String        @default("USD")
  status      InvoiceStatus @default(PENDING)
  paidAt      DateTime?
  periodStart DateTime
  periodEnd   DateTime
  externalId  String? @unique // charge ID del gateway; UNIQUE = idempotencia de webhooks a nivel BD

  createdAt DateTime @default(now())

  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURACIÓN GLOBAL DEL SAAS (MRTPVREST)
// ─────────────────────────────────────────────────────────────────────────────

model GlobalConfig {
  id                 String  @id @default("saas-config")
  basicPlanPrice     Float   @default(29)
  proPlanPrice       Float   @default(59)
  unlimitedPlanPrice Float   @default(99)
  trialDays          Int     @default(15)
  currency           String  @default("USD")
  supportEmail       String?

  // Feature flags globales (visibles en dashboard SaaS)
  openRegistration Boolean @default(true)
  autoTrial        Boolean @default(true)
  maintenanceMode  Boolean @default(false)
  whatsappEnabled  Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("global_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// SAAS API KEYS (emitidas por SUPER_ADMIN a tenants / integraciones)
// ─────────────────────────────────────────────────────────────────────────────

model SaasApiKey {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  prefix      String    @unique // primeros chars de la key (para mostrar)
  hash        String // hash completo de la key (no reversible)
  scopes      String[]  @default([])
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  requests24h Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("saas_api_keys")
}

// ─────────────────────────────────────────────────────────────────────────────
// SAAS PLATFORM LOGS (auditoría cross-tenant visible a SUPER_ADMIN)
// ─────────────────────────────────────────────────────────────────────────────

model SaasLog {
  id        String   @id @default(cuid())
  tenantId  String?
  level     String   @default("INFO") // INFO | WARN | ERROR | OK
  message   String
  context   String? // e.g. "billing · stripe"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tenantId])
  @@map("saas_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENTIDAD MAESTRA: RESTAURANTE (LA MARCA)
// ─────────────────────────────────────────────────────────────────────────────

model Restaurant {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  slug         String  @unique
  name         String
  domain       String? @unique
  isActive     Boolean @default(true)
  logoUrl      String? // Logo personalizado del cliente
  accentColor  String? // HEX extraído del logo con colorthief, ej: "#7c3aed"
  businessType String  @default("RESTAURANT") // RESTAURANT | RETAIL | GROCERY

  // BYOK — Gemini API key del cliente (cifrada AES-256-GCM).
  // Durante el trial se usa la key de la plataforma como fallback;
  // al expirar el trial esta es obligatoria.
  aiApiKey         String? // ciphertext: `<ivHex>:<tagHex>:<dataHex>`
  aiKeyValidatedAt DateTime? // última vez que se validó contra Gemini

  // Configuración Global
  config RestaurantConfig?

  // Relaciones Globales (Marca)
  locations        Location[]
  users            User[]
  categories       Category[]
  menuItems        MenuItem[]
  variantTemplates VariantTemplate[]
  loyaltyAccounts  LoyaltyAccount[]
  loyaltyRewards   LoyaltyReward[]
  coupons          Coupon[]
  integrations     IntegrationConfig[]
  orders           Order[]
  customers        Customer[]
  suppliers        Supplier[]
  whatsappSessions WhatsappSession[]
  whatsappContacts WhatsappContact[]
  whatsappConversations WhatsappConversation[]
  deliveryZones    DeliveryZone[]
  promoGames       PromoGame[]
  bulkPromos       BulkPromo[]

  // FASE INVENTARIO/COSTEO · taxonomía + recetario (multi-tenant scope)
  ingredientTypes      IngredientType[]
  ingredientCategories IngredientCategory[]
  ingredients          Ingredient[]
  recipes              Recipe[]
  subRecipes           SubRecipe[]
  modifierIngredients  ModifierIngredient[]
  pricingPolicies      PricingPolicy[]

  // FASE COMPRAS/GASTOS · taxonomía de gastos operativos (luz/agua/sueldos/etc).
  // NOTA: el modelo Expense legacy (de Logística) lleva gastos de viaje por
  // Ride/Vehicle. OperatingExpense es para gastos del local registrados
  // desde el TPV — son conceptos distintos, dejados explícitamente separados.
  operatingExpenseCategories OperatingExpenseCategory[]
  operatingExpenses          OperatingExpense[]

  // FASE BÓVEDA · dinero acumulado fuera de la gaveta del turno
  vaults         Vault[]
  vaultMovements VaultMovement[]

  // FASE COMPRAS · repartos de Bodega Central a sucursales
  stockTransfers StockTransfer[]

  // FASE NÓMINA · pago a empleados (control interno de la raya)
  payrollConfig       PayrollConfig?
  employeePayProfiles EmployeePayProfile[]
  payrollPeriods      PayrollPeriod[]
  payrollItems        PayrollItem[]
  employeeCharges     EmployeeCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("restaurants")
  // RETAIL · núcleo separado para tiendas de ropa/SKU. No reutiliza MenuItem
  // ni Ingredient para evitar acoplar el TPV retail al dominio restaurante.
  // Multigiro: el mismo núcleo sirve ropa, ferretería y refaccionaria; el giro
  // vive en RestaurantConfig.retailGiro (ver docs/plan-retail-multigiro.md).
  retailProducts       RetailProduct[]
  retailSkus           RetailSku[]
  retailStockBalances  RetailStockByLocation[]
  retailStockMovements RetailStockMovement[]
  retailSales          RetailSale[]
  retailTransfers      RetailTransfer[]
  retailDevices        RetailDevice[]
  retailSyncOutbox     RetailSyncOutbox[]
  retailCashShifts     RetailCashShift[]
  retailPriceTiers     RetailPriceTier[]
  retailPriceLists     RetailPriceList[]
  retailPriceListItems RetailPriceListItem[]
  retailFitments       RetailFitment[]
  retailCrossRefs      RetailCrossRef[]
}

// ─────────────────────────────────────────────────────────────────────────────
// SUCURSAL (LOCATION) - EL LUGAR FÍSICO
// ─────────────────────────────────────────────────────────────────────────────

enum BusinessType {
  RESTAURANT
  RETAIL
  BAR
  CAFE
  FAST_FOOD
}

model Location {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name     String
  slug     String
  address  String?
  phone    String?
  isActive Boolean @default(true)

  // Cerebro Adaptativo: tipo de negocio por sucursal
  businessType BusinessType @default(RESTAURANT)

  // FASE COMPRAS · marca esta sucursal como la Bodega Central del restaurant.
  // Sólo una sucursal por restaurant debería tenerlo en true. Sólo tiene
  // efecto cuando RestaurantConfig.centralWarehouseEnabled = true.
  isCentralWarehouse Boolean @default(false)

  // FASE 13 · CAPACIDADES POR SUCURSAL
  // Flags que activan/desactivan secciones del TPV según el modelo
  // operativo. Defaults pensados para un restaurante tradicional —
  // bares y antros típicamente apagan delivery/takeaway/tableMap y
  // encienden openTabs (cuentas abiertas rápidas por nombre).
  hasDelivery Boolean @default(true)
  hasTakeaway Boolean @default(true)
  hasTableMap Boolean @default(true)
  hasOpenTabs Boolean @default(false) // Cuentas abiertas rápidas por nombre — esencial en bares

  // Motor de Promociones Automáticas con IA
  autoPromoEnabled   Boolean @default(false)
  autoPromoThreshold Int     @default(10) // Umbral: Ventas menores a X en los últimos 7 días
  autoPromoDiscount  Float   @default(15) // % de descuento automático
  autoPromoMaxItems  Int     @default(0)  // Tope de platillos en promo a la vez (0 = sin tope)

  // Configuración de Ticket por sucursal
  ticketConfig TicketConfig?

  // Configuración remota del TPV (OTA) — override de comportamiento y branding
  // sin necesidad de reconstruir el APK.
  tpvConfig TpvRemoteConfig?

  // Operación Local
  orders            Order[]
  employees         Employee[]
  printers          Printer[]
  ingredients       Ingredient[]
  banners           Banner[]
  waiters           Waiter[]
  cashShifts        CashShift[]
  externalOrders    ExternalOrder[]
  pushSubscriptions PushSubscription[]
  tables            Table[]
  zones             Zone[]
  taxConfigs        TaxConfig[]

  devices       Device[]
  tasks         Task[]
  printerGroups PrinterGroup[]

  // FASE INVENTARIO/COSTEO · stock e inventario por sucursal
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  physicalCounts PhysicalCount[]

  // FASE COMPRAS · repartos desde la Bodega Central
  stockTransfersFrom   StockTransfer[]     @relation("TransferFromLocation")
  stockTransferItemsTo StockTransferItem[] @relation("TransferToLocation")

  // FASE COMPRAS/GASTOS · gastos operativos registrados desde el TPV
  operatingExpenses OperatingExpense[]

  // FASE BÓVEDA · una bóveda de dinero acumulado por sucursal
  vault          Vault?
  vaultMovements VaultMovement[]

  // FASE NÓMINA · corridas de raya por sucursal
  payrollPeriods PayrollPeriod[]
  employeeCharges EmployeeCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, slug])
  @@map("locations")
  // RETAIL · stock, ventas, traspasos y dispositivos por sucursal.
  retailStockBalances  RetailStockByLocation[]
  retailStockMovements RetailStockMovement[]
  retailSales          RetailSale[]
  retailTransfersFrom  RetailTransfer[]      @relation("RetailTransferFromLocation")
  retailTransferItemsTo RetailTransferItem[]  @relation("RetailTransferToLocation")
  retailDevices        RetailDevice[]
  retailCashShifts     RetailCashShift[]
}

// ─────────────────────────────────────────────────────────────────────────────
// USUARIOS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  KITCHEN
  SUPER_ADMIN
}

model User {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  name         String
  email        String  @unique
  phone        String? @unique
  passwordHash String
  role         Role    @default(CUSTOMER)
  avatarUrl    String?
  isActive     Boolean @default(true)

  // Recuperación de contraseña por email (forgot/reset-password). Token de un
  // solo uso + expiry corta (1h). Mismo patrón que emailVerificationToken del Tenant.
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  addresses     Address[]
  orders        Order[]
  loyalty       LoyaltyAccount[]
  refreshTokens RefreshToken[]
  landingEdits  LandingContent[] @relation("LandingContentUpdater")

  // FASE INVENTARIO/COSTEO · auditoría de quién movió stock / aprobó mermas
  stockMovements     StockMovement[]
  wastesApproved     WasteLog[]      @relation("WasteApprovedBy")
  purchaseOrdersMade PurchaseOrder[]
  physicalCountsLed  PhysicalCount[]

  // FASE COMPRAS/GASTOS · quién registró el gasto operativo
  operatingExpensesCreated OperatingExpense[]

  // FASE COMPRAS · quién ejecutó un reparto desde Bodega Central
  stockTransfersCreated StockTransfer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String  @default("Casa")
  street       String
  extNumber    String
  intNumber    String?
  neighborhood String
  city         String
  state        String  @default("México")
  zipCode      String
  references   String?
  lat          Float?
  lng          Float?
  isDefault    Boolean @default(false)
  orders       Order[]

  createdAt DateTime @default(now())

  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENÚ GLOBAL
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  imageUrl    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  items       MenuItem[]

  printerGroups CategoryPrinterGroup[]

  // Promociones por cantidad (NxM) que incluyen esta categoría en su pool.
  bulkPromos BulkPromoCategory[]

  // FASE INVENTARIO/COSTEO · política de margen por categoría
  pricingPolicies PricingPolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model MenuItem {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  reactions    DishReaction[]

  name            String
  description     String?
  imageUrl        String?
  // Cómo encuadrar la foto en las tarjetas del menú/tienda:
  // "cover" (default) rellena el recuadro y recorta lo que sobra,
  // "contain" muestra la foto completa sin recortar (puede dejar
  // bordes). Se configura por platillo desde /admin/menu.
  imageFit        String   @default("cover")
  price           Float
  isAvailable     Boolean  @default(true)
  // Visibilidad en la TIENDA EN LÍNEA (storefront del client). Independiente
  // de isAvailable (que controla si el producto se puede vender en general /
  // TPV). Un producto puede estar isAvailable=true (se cobra en el TPV) pero
  // availableOnline=false (no aparece ni se puede pedir desde la web). Default
  // true para no ocultar el catálogo existente al migrar.
  availableOnline Boolean  @default(true)
  // Visibilidad en el KIOSKO, independiente de la web. Migración hace backfill
  // = availableOnline para no cambiar lo que el operador ya tenía oculto.
  availableOnKiosk Boolean @default(true)
  isPopular       Boolean  @default(false)
  isPromo         Boolean  @default(false)
  // isFavorite — items que el admin destaca como "más vendidos" o de
  // rotación rápida. El TPV los muestra en un tile pinned arriba del
  // grid de categorías para que el cajero los marque con un solo tap.
  isFavorite      Boolean  @default(false)
  promoPrice      Float?
  barcode         String?
  activeDays      String[]
  hasVariants     Boolean  @default(false)
  // Unidad de venta del producto: "PIECE" (por pieza, default), "WEIGHT"
  // (por kilo / báscula) u "ORDER" (por orden/ración). PIECE y ORDER son
  // conteo entero (mismo flujo, solo cambia la etiqueta "pza"/"orden");
  // WEIGHT activa la captura de peso. Fuente de verdad de la unidad.
  saleUnit        String   @default("PIECE")
  // Unidad de medida MOSTRADA del producto (etiqueta libre seleccionable:
  // "pz","kg","g","L","ml","orden","bolsa","lata","caja","paquete","docena"…).
  // Cosmética (se ve en POS/ticket como "$X / unit"); el comportamiento de
  // cobro/captura lo dicta saleUnit/soldByWeight, no este campo.
  unit            String   @default("pz")
  // DERIVADO de saleUnit (=="WEIGHT"). Se mantiene sincronizado en las
  // escrituras del catálogo para que la lógica de cobro/inventario por peso
  // (orders.routes: resolveWeightKg) siga consultando un booleano simple.
  // Cuando es true, `price`/`promoPrice` se interpretan como PRECIO POR KG,
  // el TPV captura los kg y el OrderItem guarda el peso en `weightKg`.
  soldByWeight    Boolean  @default(false)
  // Cuando variantMultiSelect=true el TPV deja elegir varias variantes
  // (ej. varios sabores de boneless) en vez de una sola. min/max=0 = sin
  // tope por ese lado. Sólo aplica al modo multi; el single-select clásico
  // (talla S/M/L) queda intacto con estos defaults.
  variantMultiSelect  Boolean @default(false)
  variantMinSelection Int     @default(0)
  variantMaxSelection Int     @default(0)
  preparationTime Int      @default(15)
  taxCategoryId   String?

  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]
  variants       MenuItemVariant[]
  complements    MenuItemComplement[]
  recipeItems    RecipeItem[]

  // FASE INVENTARIO/COSTEO · escandallos. Receta base (variantId NULL) y/o
  // recetas por variante. Era 1:1; ahora 1:N para soportar receta por variante.
  recipes Recipe[]

  loyaltyRewards LoyaltyReward[]

  printerGroups MenuItemPrinterGroup[]

  // Combos configurables: si isCombo, este "producto" es un combo cuyos slots
  // (comboComponents) arma el cliente. comboOptionsFor = opciones de OTROS combos
  // que apuntan a este producto como elegible.
  isCombo         Boolean          @default(false)
  comboComponents ComboComponent[] @relation("ComboOwner")
  comboOptionsFor ComboOption[]    @relation("ComboOptionMenuItem")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, isFavorite])
  @@map("menu_items")
}

model ModifierGroup {
  id                 String     @id @default(cuid())
  menuItemId         String
  menuItem           MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name               String
  required           Boolean    @default(false)
  multiSelect        Boolean    @default(false)
  // Rango de selección. 0 = sin restricción por ese lado.
  // Ejemplo: "Elige 2 a 5 ingredientes" -> minSelection=2, maxSelection=5
  minSelection       Int        @default(0)
  maxSelection       Int        @default(0)
  // "Los primeros N modificadores no cobran extra" (ej. 2 toppings gratis,
  // los siguientes con priceAdd). 0 = todos cobran.
  freeModifiersLimit Int        @default(0)
  // "ADD" = extras que suman (Tocino +$20). "REMOVE" = quitar ingredientes
  // gratis (Sin cebolla). String libre (consistente con saleUnit/storefrontTheme).
  groupType          String     @default("ADD")
  modifiers          Modifier[]

  @@map("modifier_groups")
}

model Modifier {
  id                 String              @id @default(cuid())
  groupId            String
  group              ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name               String
  priceAdd           Float               @default(0)
  isDefault          Boolean             @default(false)
  isAvailable        Boolean             @default(true)
  orderItemModifiers OrderItemModifier[]

  @@map("modifiers")
}

// ─────────────────────────────────────────────────────────────────────────────
// PEDIDOS (LOCALES)
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  ON_THE_WAY
  DELIVERED
  CANCELLED
  // OPEN = cuenta abierta (dine-in): la mesa acumula rondas hasta que se cobra.
  // Se añadió al final del enum a propósito: PostgreSQL ordena los valores de
  // un enum por declaración, así que cualquier código/SQL existente que
  // dependiera del orden PENDING < CONFIRMED < ... < CANCELLED se mantiene
  // intacto.
  OPEN
  // PACKING = en empaque (verificación final antes de salir/entregar). Al final
  // del enum por la misma razón que OPEN (Postgres ordena por declaración).
  PACKING
}

enum PaymentMethod {
  CASH
  CARD_PRESENT
  TRANSFER
  COURTESY
  PENDING
  CARD
  OXXO
  SPEI
  CASH_ON_DELIVERY
  QR_CODE
  // Consumo a cuenta de un empleado: la orden se cierra SIN entrar a caja y
  // genera un EmployeeCharge que se descuenta de su raya. Ver employee_charges.
  EMPLOYEE_ACCOUNT
  // Cobro mixto (split-tender): la orden se pagó con >1 método a la vez (p.ej.
  // efectivo + tarjeta). El desglose vive en payment_transactions (Order.payments);
  // el corte de caja suma cada renglón a su bucket. Ver lib/money.normalizeTenders.
  MIXED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id           String     @id @default(cuid())
  restaurantId String
  locationId   String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  location     Location?  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // orderNumber · folio secuencial continuo POR RESTAURANTE (1, 2, 3...).
  // Lo asigna un contador atómico (ver lib/order-number.js + model Counter);
  // antes era 'TPV-' + fragmento del timestamp, que no contaba nada real.
  // La unicidad es por restaurante (@@unique abajo), NO global: cada negocio
  // tiene su propia serie 1..N sin chocar con la de otro tenant.
  orderNumber String
  // clientOrderId · idempotencia DB-level para replays de la cola offline
  // del TPV. El cliente genera el id antes de mandar (uuid o txId del outbox)
  // y el backend lo usa como llave única: si ya existe, devuelve la orden
  // existente en vez de crear duplicado. Complementa el Idempotency-Key
  // in-memory del middleware (que se pierde tras restart).
  clientOrderId String?  @unique
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  addressId   String?
  address     Address? @relation(fields: [addressId], references: [id])
  // Cliente del directorio (registro por teléfono). Nullable: ventas de
  // mostrador sin teléfono no enlazan. customerName/customerPhone se mantienen
  // como snapshot denormalizado de lo capturado en ESTA orden — el Customer
  // puede cambiar de nombre/dirección después sin reescribir órdenes viejas.
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  subtotal    Float
  deliveryFee Float @default(0)
  discount    Float @default(0)
  // promoDiscount · descuento AUTOMÁTICO de promociones por cantidad (NxM,
  // p.ej. "3x2 en alitas"). Se calcula server-side desde las líneas (ver
  // lib/bulk-promo.js) y se persiste APARTE del `discount` manual del cajero:
  // así los reportes distinguen "promo del negocio" de "descuento aplicado a
  // mano", y el recibo puede imprimir cada concepto en su renglón.
  // total = subtotal − discount − promoDiscount + deliveryFee.
  promoDiscount Float @default(0)
  tip         Float @default(0)   // propina (kiosko / dine-in)
  total       Float

  pointsEarned Int @default(0)
  pointsUsed   Int @default(0)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  notes String?

  // Etiqueta editable de la cuenta abierta (p. ej. "Mesa terraza",
  // "Cumpleaños Ana"). Independiente de customerName/tableName: permite al
  // cajero nombrar el ticket sin tocar los datos del cliente o la mesa.
  ticketName String?

  orderType        String    @default("DELIVERY")
  // tableNumber es el número plano legado (lo siguen enviando orders antiguos
  // y el flujo Quick Service). tableId es la nueva FK opcional al modelo Table
  // para Dine-in con cuentas abiertas. Ambos conviven por compatibilidad.
  tableNumber      Int?
  tableId          String?
  table            Table?    @relation(fields: [tableId], references: [id], onDelete: SetNull)
  // Cantidad de comensales declarada al iniciar la orden DINE_IN. Se usa
  // para generar tabs por comensal en el POS y para split del ticket al
  // cobrar. Nullable porque flujos no-dine-in (TAKEOUT/DELIVERY) no la
  // tienen, y orders previas a este campo tampoco.
  numberOfGuests   Int?
  source           String    @default("ONLINE")
  deliveryDriverId String?
  // Empleado del TPV que tomó/creó el pedido (Employee.id). FK escalar sin
  // relación Prisma, mismo patrón que deliveryDriverId: el nombre se resuelve
  // con consulta batch. Permite atribuir a meseros/cajeros su actividad.
  // Nullable: pedidos ONLINE y los previos a este campo no lo tienen.
  createdById      String?
  deliveryAddress  String?
  // Coordenadas del cliente (GPS del navegador en el checkout) y distancia
  // calculada al origen de la tienda. Se usan para el envío por distancia y
  // para mostrar el pin al repartidor. Nullables: TAKEOUT/DINE_IN no los tienen.
  deliveryLat        Float?
  deliveryLng        Float?
  deliveryDistanceKm Float?
  customerName     String?
  customerPhone    String?
  customerEmail    String?
  paidAt           DateTime?

  cashCollected   Boolean   @default(false)
  cashCollectedAt DateTime?
  cashCollectedBy String?

  // REEMBOLSO de un ticket YA cobrado (total o parcial). refundedAmount es el
  // acumulado devuelto (cacheado para el guard atómico anti-doble-reembolso:
  // updateMany condicional `refundedAmount <= total - monto`, mismo patrón que
  // el consumo de cupones). Al llegar a `total` la orden pasa a paymentStatus
  // REFUNDED. El asiento de caja del reembolso NO vive aquí: el efectivo que
  // sale del cajón se registra como ShiftExpense (categoría REFUND) y el de un
  // repartidor como DriverCashMovement EXPENSE — así el corte cuadra solo.
  refundedAmount Float     @default(0)
  refundedAt     DateTime?

  // Verificación de cobro por TRANSFERENCIA: el admin confirma contra el banco
  // que el SPEI de una entrega cobrada por transferencia realmente llegó. Espeja
  // el patrón de cashCollected; solo aplica a paymentMethod=TRANSFER. No bloquea
  // el corte del repartidor, solo da visibilidad/auditoría en su lista de pedidos.
  transferVerified   Boolean   @default(false)
  transferVerifiedAt DateTime?
  transferVerifiedBy String?

  conektaOrderId        String?
  conektaChargeId       String?
  paymentProvider       String? // MERCADOPAGO | STRIPE | CONEKTA | ...
  paymentProviderRef    String? // ID de checkout/preferencia
  paymentProviderId     String? @unique // ID del pago después de cobrar; UNIQUE: un pago del gateway no puede marcar dos órdenes
  paymentProviderStatus String? // status crudo de la pasarela
  estimatedMinutes      Int?

  shiftId String?
  shift   CashShift? @relation(fields: [shiftId], references: [id])

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  rounds        OrderRound[]
  payments      PaymentTransaction[]
  packingChecks OrderPackingCheck[]

  // FASE NÓMINA · si la orden se cobró "a cuenta de empleado", aquí cuelga el
  // cargo generado (1:1). Nullable: la inmensa mayoría de órdenes no lo tienen.
  employeeCharge EmployeeCharge?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, orderNumber])
  @@index([tableId])
  @@index([customerId])
  @@index([createdById])
  @@map("orders")
}

// ─────────────────────────────────────────────────────────────────────────────
// COUNTER — Contadores secuenciales atómicos por restaurante.
// Hoy un solo scope ("order") = folio continuo de órdenes (1, 2, 3...). El
// valor se incrementa DENTRO de la misma $transaction que crea la orden, así
// dos cobros simultáneos nunca sacan el mismo folio ni se saltan números.
// Ver helper apps/backend/src/lib/order-number.js. Sin relación Prisma a
// Restaurant a propósito (es metadata interna, no se navega desde el tenant).
// ─────────────────────────────────────────────────────────────────────────────

model Counter {
  id           String @id @default(cuid())
  restaurantId String
  // scope: tipo de serie. "order" = folio de órdenes. Deja la puerta abierta a
  // futuras series (cotizaciones, compras...) sin otra tabla.
  scope        String @default("order")
  value        Int    @default(0)

  updatedAt DateTime @updatedAt

  @@unique([restaurantId, scope])
  @@map("counters")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENTE (CUSTOMER) — Directorio de clientes por teléfono (multi-tenant).
// El teléfono normalizado (solo dígitos) es la llave de negocio dentro de cada
// restaurante: al meter un pedido el TPV busca por teléfono y autocompleta
// nombre/dirección. ordersCount/totalSpent/lastOrderAt son denormalizados que
// se actualizan en cada creación de orden para mostrar "cliente frecuente" sin
// agregar al vuelo. No guarda PII sensible más allá de contacto y dirección.
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // phone: dígitos normalizados (sin +, espacios ni guiones). Llave única por
  // restaurante. name/address guardan los últimos valores capturados.
  phone   String
  name    String?
  address String?

  ordersCount Int       @default(0)
  totalSpent  Float     @default(0)
  lastOrderAt DateTime?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, phone])
  @@index([restaurantId, phone])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT TRANSACTIONS — Una orden puede tener N pagos (split payment).
// Ej: 200 efectivo + 300 tarjeta. Si solo hay un pago, equivale al método
// único legado en Order.paymentMethod (que se mantiene como source of truth
// del "método primario" para retrocompatibilidad).
// ─────────────────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method PaymentMethod
  amount Float
  status PaymentStatus @default(PENDING)

  // Datos crudos del gateway (Stripe/Conekta/MercadoPago/...)
  gateway        String? // "MANUAL" | "STRIPE" | "CONEKTA" | "MERCADOPAGO"
  externalId     String? // charge / payment id
  externalRef    String? // checkout / preference id
  externalStatus String? // status crudo del gateway

  // Cuando este pago se acreditó. Null mientras está PENDING/FAILED.
  paidAt DateTime?
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("payment_transactions")
}

model OrderItem {
  id         String              @id @default(cuid())
  orderId    String
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id])
  name       String
  price      Float
  quantity   Int
  // Peso vendido en KG para productos `MenuItem.soldByWeight`. Cuando está
  // presente, `quantity` queda en 1 y la línea se cobró como
  // `price (por kg) × weightKg`; el inventario se descontó proporcional al
  // peso. Null para los productos por pieza (la inmensa mayoría). Decimal
  // (no Float) por la regla de dinero/precisión del proyecto.
  weightKg   Decimal?            @db.Decimal(10, 3)
  subtotal   Float
  notes      String?
  modifiers  OrderItemModifier[]

  // Agrupación por ronda de comanda. Nullable para ítems creados antes de
  // introducir el concepto (y para el flujo Quick Service que manda todo en
  // una sola ronda implícita).
  roundId String?
  round   OrderRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)

  // Comensal al que pertenece este ítem dentro de la orden DINE_IN
  // (1..numberOfGuests). Nullable para flujos no-dine-in y para items
  // compartidos por toda la mesa (entrada, postre para todos, etc.). El
  // split del ticket al cobrar agrupa por seatNumber; los nullables van a
  // la cuenta común.
  seatNumber Int?

  // FASE 11 · COURSING — Tiempo en el que se debe servir este item.
  // Valores libres por flexibilidad ("ENTRADA", "FUERTE", "POSTRE",
  // "BEBIDA", o customs por restaurante). Cocina puede agruparlos para
  // emitir comandas separadas por tiempo y evitar que el plato fuerte
  // salga antes que la entrada.
  course String?

  // FASE INVENTARIO/COSTEO · SNAPSHOT INMUTABLE al cobrar.
  // Si el costo de un ingrediente sube/baja después de esta venta, los
  // reportes históricos NO se recalculan. Esta es la única forma de
  // tener números contables defendibles ante el cliente y Hacienda.
  costSnapshot Float? // CMV (costo de materia prima) al momento de venta
  recipeIdSnap String? // id de Recipe usada (auditoría — referencia débil, no FK)

  // Combos: selección del cliente por componente (snapshot histórico).
  comboSelections ComboSelection[]

  @@index([roundId])
  @@index([seatNumber])
  @@index([course])
  @@map("order_items")
}

// ── COMBOS CONFIGURABLES ──────────────────────────────────────────────────
// Un combo es un MenuItem con isCombo=true. Sus slots (Principal, Guarnición,
// Bebida…) son ComboComponent; cada slot ofrece ComboOption que apunta a un
// MenuItem real (con priceDelta de upgrade). La selección del cliente se
// snapshotea en ComboSelection (hija de OrderItem). Ningún modelo lleva
// restaurantId (el scope sube por el MenuItem dueño) → no van a SCOPED_MODELS.
model ComboComponent {
  id         String        @id @default(cuid())
  menuItemId String
  menuItem   MenuItem      @relation("ComboOwner", fields: [menuItemId], references: [id], onDelete: Cascade)
  name       String
  minSelect  Int           @default(1)
  maxSelect  Int           @default(1)
  isRequired Boolean       @default(true)
  sortOrder  Int           @default(0)
  options    ComboOption[]

  @@index([menuItemId])
  @@map("combo_components")
}

model ComboOption {
  id               String         @id @default(cuid())
  componentId      String
  component        ComboComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  // El MenuItem real elegible. Cascade (NO Restrict) para no romper el borrado
  // de productos ni el wipe-all: si se borra el producto, su opción desaparece.
  optionMenuItemId String
  optionMenuItem   MenuItem       @relation("ComboOptionMenuItem", fields: [optionMenuItemId], references: [id], onDelete: Cascade)
  priceDelta       Float          @default(0)
  isAvailable      Boolean        @default(true)
  sortOrder        Int            @default(0)

  @@index([componentId])
  @@map("combo_options")
}

model ComboSelection {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  // Referencias blandas (sin FK): el componente/opción pueden borrarse después
  // de la venta; el snapshot de nombre/precio/optionMenuItemId queda inmutable.
  componentId      String?
  optionId         String?
  optionMenuItemId String
  name             String
  priceDelta       Float   @default(0)

  @@index([orderItemId])
  @@map("combo_selections")
}

// ── EMPAQUE ────────────────────────────────────────────────────────────────
// Checklist de verificación por pedido en la etapa PACKING. Sin restaurantId (el
// scope sube por la Order) → no entra a SCOPED_MODELS. checkedById es referencia
// blanda (string sin FK) al empleado que marcó.
model OrderPackingCheck {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  checkKey    String    // DRINKS_COMPLETE | SAUCES_PACKED | TICKET_PRINTED | ADDRESS_CONFIRMED | PAYMENT_CONFIRMED
  checked     Boolean   @default(false)
  checkedAt   DateTime?
  checkedById String?

  @@unique([orderId, checkKey])
  @@index([orderId])
  @@map("order_packing_checks")
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  // El nombre y el precio quedan congelados como snapshot (name/priceAdd), así que
  // el historial de la orden NO depende del Modifier vivo. Por eso, al borrar un
  // modificador del menú que ya se usó en órdenes, la FK pone modifierId en null
  // (SetNull) en lugar de bloquear el borrado con Restrict.
  modifierId  String?
  modifier    Modifier? @relation(fields: [modifierId], references: [id], onDelete: SetNull)
  name        String
  priceAdd    Float

  @@map("order_item_modifiers")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@map("order_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEALTAD & CUPONES
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyAccount {
  id           String               @id @default(cuid())
  restaurantId String
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  points       Int                  @default(0)
  totalEarned  Int                  @default(0)
  tier         LoyaltyTier          @default(BRONZE)
  qrCode       String               @unique
  transactions LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, restaurantId])
  @@map("loyalty_accounts")
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
}

enum LoyaltyTxType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        LoyaltyTxType
  points      Int
  description String
  orderId     String?
  createdAt   DateTime       @default(now())

  @@map("loyalty_transactions")
}

// Catálogo de recompensas canjeables por puntos (lealtad Fase 3). Una
// recompensa otorga UN producto gratis (menuItemId) O un descuento fijo en $
// (discountAmount) — exactamente uno de los dos. El canje vive en
// store.routes.js /orders (mismo patrón transaccional que el canje genérico
// de puntos: decremento condicional en el WHERE).
model LoyaltyReward {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  pointsCost     Int
  menuItemId     String?
  menuItem       MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  discountAmount Decimal?   @db.Decimal(12, 2)
  isActive       Boolean    @default(true)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([restaurantId])
  @@map("loyalty_rewards")
}

model Coupon {
  id             String       @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  code           String       @unique
  description    String
  discountType   DiscountType
  // Etapa 1 de la migración Float→Decimal (docs/plan-decimal-migration.md):
  // piloto de bajo riesgo. El replacer JSON global del backend serializa
  // Decimal como number, así que el contrato HTTP no cambia.
  discountValue  Decimal      @db.Decimal(12, 2)
  minOrderAmount Decimal      @default(0) @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  orders         Order[]

  createdAt DateTime @default(now())

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────────────────────────────────────
// BULK PROMO — Promociones por cantidad (NxM): "compra N, paga M".
//
// El caso canónico es el 3x2 (buyQuantity=3, payQuantity=2): por cada bloque de
// 3 unidades de los productos elegibles, 1 sale gratis. Generaliza a cualquier
// NxM (2x1 cervezas, 4x3, etc.) sin tocar código.
//
// POOL COMBINADO: una promo agrupa N categorías (Alitas + Boneless cuentan
// JUNTAS para sumar el bloque). La regla de "qué sale gratis" es siempre la
// unidad MÁS BARATA de cada bloque (estándar de industria, protege el margen) —
// esa lógica vive en lib/bulk-promo.js, no en el schema.
//
// El descuento NO requiere el permiso apply_discount del cajero: es una promo
// del negocio, automática. Se calcula en la misma $transacción que crea la
// orden y se persiste en Order.promoDiscount.
// ─────────────────────────────────────────────────────────────────────────────

model BulkPromo {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name        String // "3x2 Alitas y Boneless"
  buyQuantity Int     @default(3) // compra N
  payQuantity Int     @default(2) // paga M (descuento = N−M unidades más baratas por bloque)
  isActive    Boolean @default(true)
  // Vigencia opcional. null = sin límite por ese lado. La promo aplica cuando
  // isActive=true Y (startsAt null o <= now) Y (endsAt null o >= now).
  startsAt    DateTime?
  endsAt      DateTime?
  // Ventana horaria DIARIA opcional ("HH:mm", hora local del restaurante).
  // null = sin límite por ese lado. endTime "21:00" = la promo deja de aplicar
  // después de las 9 pm. startTime > endTime = ventana que cruza medianoche.
  startTime   String?
  endTime     String?

  // Pool de categorías elegibles (M:N vía tabla join explícita, igual que el
  // resto del schema). Sus productos suman JUNTOS para formar los bloques NxM.
  categories BulkPromoCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, isActive])
  @@map("bulk_promos")
}

// Join explícito BulkPromo ↔ Category (pool combinado del NxM).
model BulkPromoCategory {
  bulkPromoId String
  bulkPromo   BulkPromo @relation(fields: [bulkPromoId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bulkPromoId, categoryId])
  @@index([categoryId])
  @@map("bulk_promo_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURACIÓN
// ─────────────────────────────────────────────────────────────────────────────

model RestaurantConfig {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  phone             String?
  whatsappNumber    String?
  whatsappOrderingEnabled Boolean @default(false)

  // Aviso al DUEÑO/negocio por WhatsApp cuando entra un pedido web (además del
  // push al TPV). Número separado del público para no chocar con el bot/
  // contacto. Si orderAlertWhatsapp está vacío se cae a `phone`. Requiere
  // orderAlertEnabled + un número resoluble para disparar.
  orderAlertEnabled   Boolean @default(false)
  orderAlertWhatsapp  String?
  address           String?

  // País del restaurante (ISO 3166-1 alpha-2: "MX", "US", "CO", …). Determina la
  // lada que se antepone a los teléfonos para los enlaces/notificaciones de
  // WhatsApp. Ver packages/config/phone.js para el mapeo país→lada.
  countryCode       String  @default("MX")

  // Giro del tenant retail: ROPA | FERRETERIA | REFACCIONARIA. Decide el esquema
  // de atributos del SKU y los labels/íconos de la app Retail+ (apps/moda).
  // Es ORTOGONAL a Location.businessType (enum): ése dice "es mostrador"
  // (preset operativo del TPV), éste dice CUÁL vertical. Ver
  // docs/plan-retail-multigiro.md → "Dónde vive el giro".
  // Texto libre (no enum) para agregar giros sin migración; la app valida
  // contra apps/moda/src/lib/giro.ts y cae a ROPA si no reconoce el valor.
  retailGiro        String  @default("ROPA")

  deliveryFee       Float   @default(0)
  freeDeliveryFrom  Float?
  minOrderAmount    Float   @default(0)
  estimatedDelivery Int     @default(40)
  isOpen            Boolean @default(true)
  closedMessage     String?

  // FRENO DE SATURACIÓN · tope de pedidos en cocina para canales remotos.
  // Si maxOpenOrders > 0 y los pedidos abiertos del restaurante (PENDING/
  // CONFIRMED/PREPARING creados en las últimas 2h, de cualquier canal)
  // alcanzan el tope, la tienda online y el bot de WhatsApp rechazan pedidos
  // nuevos con 429 STORE_SATURATED. El TPV y el kiosko nunca se bloquean.
  // null/0 → sin freno. saturatedMessage = texto que ve el cliente (opcional).
  maxOpenOrders    Int?
  saturatedMessage String?

  // ─── HORARIO DE ATENCIÓN ───────────────────────────────────────────────
  // scheduleEnabled: si true, la apertura se calcula con el reloj local
  // (timezone) contra businessHours. isOpen sigue siendo el override "forzar
  // cerrado": isOpen=false cierra la tienda sin importar el horario.
  scheduleEnabled Boolean @default(false)
  timezone        String  @default("America/Mexico_City")
  // businessHours: JSON con una franja por día (0=Dom … 6=Sáb):
  // [{ "day":1, "enabled":true, "open":"09:00", "close":"22:00" }, ...]
  businessHours   String  @default("[]")

  // ─── VENTANA HORARIA DE PROMOCIONES ────────────────────────────────────
  // Horario diario ("HH:mm", hora local según `timezone`) en el que aplican
  // los precios promocionales de platillos (isPromo/promoPrice). Fuera de la
  // ventana los platillos promo se OCULTAN del catálogo (TPV/tienda/bot) y,
  // como respaldo, se cobran a precio normal. null = sin límite por ese lado.
  // promoEndTime "21:00" = las promos terminan a las 9 pm.
  promoStartTime String?
  promoEndTime   String?

  // ─── ENVÍO POR DISTANCIA ───────────────────────────────────────────────
  // deliveryMode controla cómo se calcula el costo de envío:
  //   FLAT     → tarifa fija = deliveryFee (comportamiento histórico).
  //   DISTANCE → deliveryBaseFee + (deliveryPerKm × distancia_km), con radio
  //              de envío gratis y distancia máxima de cobertura opcionales.
  //   ZONES    → tarifa por polígono: la coordenada del cliente cae dentro de
  //              una DeliveryZone dibujada en el mapa y se cobra su fee. Fuera
  //              de toda zona = OUT_OF_RANGE (sin cobertura).
  // El origen (originLat/originLng) es la ubicación de la tienda desde donde
  // se mide la distancia al cliente (GPS del navegador en el checkout).
  deliveryMode         String @default("FLAT") // FLAT | DISTANCE | ZONES
  originLat            Float?
  originLng            Float?
  deliveryBaseFee      Float  @default(0)
  deliveryPerKm        Float  @default(0)
  deliveryFreeRadiusKm Float? // dentro de este radio, envío gratis
  deliveryMaxKm        Float? // fuera de este radio, no hay cobertura

  pointsPerTen     Int   @default(1)
  pointsValuePesos Float @default(0.10)

  // Bono de bienvenida: puntos que se abonan UNA sola vez al crear la cuenta de
  // lealtad desde el registro del storefront (LoyaltyTransaction tipo BONUS).
  // 0 = sin bono. El abono va en el mismo create anidado que la cuenta, así que
  // es atómico y no se puede repetir (User.email es único global). Las cuentas
  // creadas al vuelo por loyalty.service NO reciben bono: no son un registro.
  welcomeBonusPoints Int @default(0)

  storefrontTheme String @default("KAWAII") // KAWAII | HALO | BRUTALIST | ANTOJO | MUNDIALISTA

  // Moneda de la tienda. Antes el símbolo "$" y "es-MX" estaban hardcodeados en
  // el storefront; ahora cada negocio elige su moneda (ISO 4217) y locale de
  // formato. El precio se guarda igual (Float en la moneda base); esto solo
  // cambia cómo se muestra.
  currency       String @default("MXN") // ISO 4217: MXN, USD, EUR, COP…
  currencyLocale String @default("es-MX") // locale de formato Intl

  // Imagen de portada (hero) opcional del storefront. La usa el tema Mundialista
  // a todo lo ancho. Se sube sin recorte (mode=hero). null → hero por defecto.
  storefrontHeroUrl String?

  // FASE COMPRAS · interruptor maestro del modelo "Bodega Central".
  // false (default) → cada compra entra directo a la bodega de la sucursal
  // (flujo simple, sin cambios para clientes de una sola sucursal).
  // true → las compras entran a la sucursal marcada isCentralWarehouse y
  // luego se reparten a las demás vía StockTransfer.
  centralWarehouseEnabled Boolean @default(false)

  // INVENTARIO · si true, crear una orden valida el stock de insumos contra las
  // recetas y RECHAZA (409) si no alcanza. Default false: el comportamiento
  // legacy (descuento best-effort post-cobro, sin bloqueo) se mantiene intacto.
  blockOnInsufficientStock Boolean @default(false)

  // EMPAQUE · si true, las órdenes pasan por la etapa PACKING (checklist de
  // verificación en KDS) antes de READY. Default false: el flujo legacy (cocina
  // marca READY directo) queda intacto para los ~tenants sin empaque.
  hasPackingStage Boolean @default(false)

  // CORTE DE CAJA · si true (default), los roles admin ven el efectivo
  // esperado aunque el turno sea ciego. false → corte ciego también para
  // admins (solo el permiso explícito canViewExpectedCash lo revela).
  adminCanViewExpectedCash Boolean @default(true)

  // CORTE DE CAJA · envío del corte por correo al cierre del turno. Si
  // cashCutEmailEnabled es true, al cerrar la caja se manda el resumen del
  // corte (ventas por método, efectivo esperado, varianza) a los correos de
  // cashCutEmails (lista separada por coma/;). Vacío → cae a los correos de
  // los admins del restaurante. El envío es best-effort: nunca bloquea ni
  // revierte el cierre.
  cashCutEmailEnabled Boolean @default(false)
  cashCutEmails       String?

  updatedAt DateTime @updatedAt

  @@map("restaurant_config")
}

model TicketConfig {
  id         String    @id @default(cuid())
  locationId String?   @unique
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  businessName String
  header       String  @default("")
  subheader    String  @default("")
  footer       String  @default("Gracias por su preferencia")
  showLogo     Boolean @default(true)
  showAddress  Boolean @default(true)
  showPhone    Boolean @default(true)
  address      String  @default("")
  phone        String  @default("")
  logoUrl      String?

  // Datos fiscales del emisor (encabezado del recibo). Vacío = no se imprime
  // la línea correspondiente (degradan a omitidos en el builder ESC/POS).
  businessType String  @default("") // giro comercial (ej. "Restaurante")
  rfc          String  @default("") // RFC del emisor

  // Bloque de autofactura por QR al pie del recibo. invoiceFolioPrefix se
  // antepone al número de orden para formar el folio (ej. "MB-" → "MB-01042").
  showInvoiceQr      Boolean @default(false)
  invoiceUrl         String  @default("") // destino del QR (portal de facturación)
  invoiceFolioPrefix String  @default("")

  // Envío (DELIVERY): ¿el costo de envío causa IVA? Si false, el recibo excluye
  // el envío de la base gravable del desglose de IVA incluido. Default true
  // (envío con IVA incluido, igual que el resto del ticket).
  deliveryFeeTaxed Boolean @default(true)

  // QR de lealtad al pie del recibo: el cliente lo escanea para registrarse en
  // la tienda en línea y acumular puntos. loyaltyUrl = destino (tienda/registro).
  showLoyaltyQr Boolean @default(false)
  loyaltyUrl    String  @default("")

  // Nuevas opciones de personalización
  paperWidth  String  @default("80mm") // "58mm" | "80mm"
  fontFamily  String  @default("monospace") // "monospace" | "sans-serif" | "serif"
  fontSize    String  @default("medium") // "small" | "medium" | "large"
  compactMode Boolean @default(false)

  // Tipografía del recibo (cliente) — /admin/tickets. lineSpacing = interlineado
  // (ESC 3); lineWeight = qué tan marcadas van las líneas (light=normal,
  // normal=énfasis en total, bold=negrita+doble golpe en todo).
  lineSpacing String @default("normal") // "tight" | "normal" | "loose"
  lineWeight  String @default("normal") // "light" | "normal" | "bold"

  showOrderNumber  Boolean @default(true)
  showCustomerData Boolean @default(true)
  showItemsPrice   Boolean @default(true)

  // ── Recibo: opciones POR LÍNEA (de-clutter del ticket) ───────────────────
  // Controlan cómo se imprime CADA línea de producto en el recibo del cliente.
  // itemSpacing = aire entre productos ("loose" mete una línea en blanco entre
  // ítems); showItemSeparator = línea punteada entre productos; modifierIndent =
  // sangría de los modificadores/notas; receiptShowModifiers/receiptShowNotes los
  // gatean (las notas son opt-in: históricamente el recibo no las imprimía).
  itemSpacing          String  @default("normal") // "tight" | "normal" | "loose"
  showItemSeparator    Boolean @default(false)
  modifierIndent       String  @default("normal") // "none" | "normal" | "wide"
  receiptShowModifiers Boolean @default(true)
  receiptShowNotes     Boolean @default(false)

  showWifi     Boolean @default(false)
  wifiSsid     String?
  wifiPassword String?

  // Datos para pagar por TRANSFERENCIA, impresos SOLO en la cuenta PENDIENTE
  // de pago (paid=false): banco, titular y CLABE/cuenta para que el cliente
  // pueda transferir. El recibo ya pagado no los imprime.
  showTransferData      Boolean @default(false)
  transferBank          String  @default("")
  transferAccountName   String  @default("")
  transferAccountNumber String  @default("")

  showPoints          Boolean @default(true)
  showTip             Boolean @default(true)
  tipSuggestions      String  @default("[10,15,20]")
  kitchenHeader       String  @default("")
  kitchenLayout       String?
  adminPin            String  @default("0000")
  kitchenShowCustomer Boolean @default(true)
  kitchenShowTable    Boolean @default(true)
  kitchenShowType     Boolean @default(true)
  kitchenShowTime     Boolean @default(true)
  // Toggles adicionales para personalizar la comanda — controlados desde
  // /admin/tickets (sección "Configuración de Comandas").
  kitchenShowOrderNumber Boolean @default(true)
  kitchenShowModifiers   Boolean @default(true)
  kitchenShowNotes       Boolean @default(true)
  // Imprime el desglose de combos/promos (description gateada por isPromo) como
  // sub-línea en la comanda. Opt-in (default false), se controla desde
  // /admin/tickets. El nombre del combo queda limpio en botón/recibo.
  kitchenShowItemDescription Boolean @default(false)
  // Agrupa items por COMENSAL N en DINE_IN con varios asientos. OFF = plano.
  kitchenGroupBySeat     Boolean @default(true)
  kitchenSeparateByGroup Boolean @default(false)
  // "normal" | "large" | "xlarge" — controla doble/triple alto de items.
  kitchenFontSize        String  @default("large")
  // Tipografía de la comanda — espejo de la del recibo.
  kitchenFontFamily      String  @default("monospace") // "monospace" | "sans-serif" | "serif"
  kitchenLineSpacing     String  @default("normal")    // "tight" | "normal" | "loose"
  kitchenLineWeight      String  @default("bold")      // "light" | "normal" | "bold"
  // Tamaño del NOMBRE del ticket (Mesa N / cliente) en la comanda — se imprime
  // arriba y prominente para que cocina identifique la cuenta de un vistazo.
  kitchenTicketNameSize  String  @default("large")     // "normal" | "large" | "xlarge"
  // Pie opcional ("Verificar antes de servir", número de turno, etc.).
  kitchenFooter          String  @default("")

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// OTROS (LOCALES)
// ─────────────────────────────────────────────────────────────────────────────

model Printer {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name           String
  // type = rol de la impresora (KITCHEN/BAR/FRYER/CASHIER). Lo mantenemos como
  // String libre por retrocompatibilidad con datos existentes.
  type           String            @default("KITCHEN")
  // connectionType = transporte físico. NETWORK es el único funcionalmente
  // operativo hoy; USB/BLUETOOTH se guardan para UI pero requieren un plugin
  // nativo de Capacitor (próxima iteración).
  connectionType PrinterConnection @default(NETWORK)

  // Campos específicos por transporte. Todos nullable porque sólo el relevante
  // al connectionType se llena.
  ip               String? // NETWORK: IP del print-server embebido
  port             Int     @default(9100)
  usbPort          String? // USB: device path (p. ej. /dev/usb/lp0)
  bluetoothAddress String? // BLUETOOTH: MAC del dispositivo

  // ¿Esta impresora tiene un cajón de dinero conectado al puerto drawer?
  // Cuando es true + type=CASHIER, el backend le manda ESC/POS kick al
  // confirmar un cobro en efectivo.
  supportsCashDrawer Boolean @default(false)

  isActive   Boolean  @default(true)
  // stations[] aplica solo a "impresoras" virtuales tipo KDS: lista de
  // estaciones que esa pantalla vigila (KITCHEN, BAR, GRILL, FRYER...).
  // Vacío = fallback al campo `type` single (impresoras térmicas
  // tradicionales). Permite que un KDS tipo "cocina central" muestre
  // pedidos de varias estaciones a la vez.
  stations   String[] @default([])

  // Printer Groups: un Printer puede pertenecer a N
  // grupos de impresión. Las comandas se enrutan al group de su
  // categoría / item, y todas las impresoras del group reciben copia.
  printerGroups PrinterGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────
// PRINTER GROUPS — Modelo de enrutamiento de comandas.
//
// Un grupo agrupa N impresoras (térmicas + KDS) que reciben las mismas
// comandas. Las categorías y los items se asignan a uno o más grupos:
// cuando se cobra una orden, cada item se enruta al grupo definido en
// su Item (override) o, si no tiene, al grupo de su Categoría.
// Multi-grupo: un mismo item puede ir a varios grupos a la vez (cocina
// + barra), lo cual genera una copia del ticket en cada uno.
// ──────────────────────────────────────────────────────────────────────────

model PrinterGroup {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    PrinterGroupMember[]
  categories CategoryPrinterGroup[]
  items      MenuItemPrinterGroup[]

  @@unique([locationId, name])
  @@index([locationId])
  @@map("printer_groups")
}

model PrinterGroupMember {
  id             String       @id @default(cuid())
  printerGroupId String
  printerGroup   PrinterGroup @relation(fields: [printerGroupId], references: [id], onDelete: Cascade)
  printerId      String
  printer        Printer      @relation(fields: [printerId], references: [id], onDelete: Cascade)

  @@unique([printerGroupId, printerId])
  @@index([printerId])
  @@map("printer_group_members")
}

model CategoryPrinterGroup {
  id             String       @id @default(cuid())
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  printerGroupId String
  printerGroup   PrinterGroup @relation(fields: [printerGroupId], references: [id], onDelete: Cascade)

  @@unique([categoryId, printerGroupId])
  @@index([printerGroupId])
  @@map("category_printer_groups")
}

model MenuItemPrinterGroup {
  id             String       @id @default(cuid())
  menuItemId     String
  menuItem       MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  printerGroupId String
  printerGroup   PrinterGroup @relation(fields: [printerGroupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, printerGroupId])
  @@index([printerGroupId])
  @@map("menu_item_printer_groups")
}

model Banner {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  title         String    @default("")
  description   String    @default("")
  imageUrl      String
  linkType      String    @default("NONE")
  linkValue     String    @default("")
  isActive      Boolean   @default(false)
  sortOrder     Int       @default(0)
  scheduleDays  String    @default("[]")
  scheduleStart String    @default("")
  scheduleEnd   String    @default("")
  dateFrom      DateTime?
  dateTo        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Supplier {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name        String
  contact     String       @default("")
  phone       String       @default("")
  email       String       @default("")
  address     String       @default("")
  notes       String       @default("")
  isActive    Boolean      @default(true)
  ingredients Ingredient[]

  // ── Suggested PO inputs ──
  // leadTimeDays  → días entre que se manda la PO y llega el pedido.
  //                  Se usa para detectar cuándo lanzar la sugerencia.
  // minOrderAmount → tope mínimo de compra (MXN) que el proveedor exige.
  //                  Si la sugerencia queda por debajo, mostramos warning.
  leadTimeDays   Int   @default(3)
  minOrderAmount Float @default(0)

  // FASE INVENTARIO/COSTEO · multi-supplier + órdenes de compra
  ingredientSuppliers IngredientSupplier[]
  purchaseOrders      PurchaseOrder[]
  operatingExpenses   OperatingExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
}

// FASE INVENTARIO/COSTEO · Ingrediente normalizado a baseUnit (g/ml/pz).
// Mantiene campos legacy (unit, cost, conversionFactor) para no romper
// código existente en orders.routes/inventory.routes que aún los usa.
// Migración gradual: nuevas features (Recipe, StockMovement) usan
// baseUnit + costPerBase calculado.
model Ingredient {
  id           String     @id @default(cuid())
  // restaurantId redundante con location.restaurantId pero indispensable
  // para queries cross-location y para FKs polimórficas en StockMovement.
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String?
  location     Location?  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // ── Taxonomía referenciable (TIPO + CATEGORIA) ──
  typeId     String?
  type       IngredientType?     @relation(fields: [typeId], references: [id])
  categoryId String?
  category   IngredientCategory? @relation(fields: [categoryId], references: [id])

  // ── Unidad base normalizada (lo que dicta el Excel real) ──
  // Toda receta, stock y movimiento se mide en esta unidad.
  baseUnit IngredientBaseUnit @default(PIECE)

  // ── Compras ──
  unit             String  @default("pz") // LEGACY: unidad libre
  purchaseUnit     String? // "Caja de 24", "Bulto 25kg"
  purchaseQty      Float   @default(1) // cantidad por unidad de compra (24, 25000g, etc.)
  purchaseCost     Float? // precio de la unidad de compra
  conversionFactor Float   @default(1) // LEGACY: purchase → base (mantener por compat)

  // ── Factor de corrección (peso bruto → neto, merma de prep) ──
  // Distinto del conversionFactor. Ej: longaniza 1000g bruto → 950g neto.
  pesoBruto Float? // cantidad comprada (mismas unidades que purchaseQty)
  pesoNeto  Float? // cantidad utilizable después de pelar/limpiar/desemilar

  // ── Stock ──
  stock    Float @default(0) // en baseUnit
  minStock Float @default(0) // umbral de alerta

  // costPerBase (computed en código): purchaseCost / purchaseQty / (pesoNeto/pesoBruto)
  cost Float @default(0) // LEGACY cache de costPerBase para reportes rápidos

  barcode String?

  // ── Flags ──
  isPackaging Boolean @default(false) // empaque para delivery (charolas, vasos)
  isActive    Boolean @default(true)
  isPendingReview Boolean @default(false) // Creado por IA, pendiente asignar costo

  // ── Multi-supplier ──
  supplierId String?
  supplier   Supplier?            @relation(fields: [supplierId], references: [id])
  suppliers  IngredientSupplier[]

  // ── Relaciones ──
  recipeItems         RecipeItem[]
  subRecipeItems      SubRecipeItem[]
  stockMovements      StockMovement[]
  batches             InventoryBatch[]
  purchaseOrderItems  PurchaseOrderItem[]
  physicalCountItems  PhysicalCountItem[]
  stockTransferItems  StockTransferItem[]
  costHistory         IngredientCostHistory[]
  modifierIngredients ModifierIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([restaurantId, isPackaging])
  @@index([restaurantId, typeId])
  @@index([restaurantId, categoryId])
  @@index([locationId])
}

// ── IngredientCostHistory ─────────────────────────────────────────────────
// Registra cada cambio de purchaseCost/cost de un ingrediente. Habilita
// gráficas de evolución de precio y detección de erosión de margen por
// alzas de proveedor. Se llena via cost-history.service en la misma tx que
// la actualización del Ingredient.
model IngredientCostHistory {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  cost             Float   // costo por unidad base
  purchaseCost     Float?  // costo de la unidad de compra
  purchaseUnit     String?
  conversionFactor Float?

  changedBy String? // userId o employeeId que disparó el cambio
  reason    String? // manual_update | supplier_invoice | voice_agent | bulk_import | purchase_receipt

  createdAt DateTime @default(now())

  @@index([ingredientId, createdAt])
  @@map("ingredient_cost_history")
}

model InventoryBatch {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  quantity       Float // Cantidad inicial del lote
  currentStock   Float // Cantidad disponible actualmente
  cost           Float // Costo de adquisición de este lote
  sku            String? // Código de barras o SKU
  expirationDate DateTime? // Clave para abarrotes/retail
  receivedAt     DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inventory_batches")
}

// RecipeItem · ítem dentro de una receta (Recipe) o de la receta directa
// del MenuItem (legacy). Permite también apuntar a una SubRecipe.
// Reglas (validar en código, no en DB):
//   - exactamente UNO de {recipeId, menuItemId} debe estar presente
//   - exactamente UNO de {ingredientId, subRecipeId} debe estar presente
model RecipeItem {
  id String @id @default(cuid())

  // Pertenece a una Recipe (nuevo) o directamente a un MenuItem (legacy).
  recipeId   String?
  recipe     Recipe?   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  // Lo que se consume: un Ingredient directo o una SubRecipe.
  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  subRecipeId  String?
  subRecipe    SubRecipe?  @relation(fields: [subRecipeId], references: [id])

  quantity       Float // cantidad en `unit`
  unit           IngredientBaseUnit @default(GRAM)
  wastagePercent Float              @default(0) // % de merma adicional al usar
  notes          String?

  createdAt DateTime @default(now())

  @@index([recipeId])
  @@index([menuItemId])
  @@index([ingredientId])
  @@index([subRecipeId])
}

// InventoryMovement · ELIMINADO 2026-05-13. Reemplazado por StockMovement
// (libro mayor unificado con balanceAfter cacheado, refType polimórfico,
// y reason tipado como enum). Todos los consumidores (orders.routes,
// inventory.routes, voice-agent.service) migrados. Si necesitas la data
// histórica antes de este reset, recuperarla del backup de Supabase del
// día anterior.

model Waiter {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name      String
  pin       String
  photo     String?
  isActive  Boolean       @default(true)
  tables    String[]
  shifts    WaiterShift[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model WaiterShift {
  id        String    @id @default(cuid())
  waiterId  String
  waiter    Waiter    @relation(fields: [waiterId], references: [id])
  startAt   DateTime  @default(now())
  endAt     DateTime?
  createdAt DateTime  @default(now())
}

model Employee {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name          String
  photo         String?
  phone         String?
  pin           String
  offlinePin    String?
  role          String   @default("WAITER")
  isActive      Boolean  @default(true)
  tables        String[]
  scheduleStart String?
  scheduleEnd   String?
  scheduleDays  String[]

  canCharge        Boolean @default(false)
  canDiscount      Boolean @default(false)
  canModifyTickets Boolean @default(false)
  canDeleteTickets Boolean @default(false)
  canConfigSystem  Boolean @default(false)
  canTakeDelivery  Boolean @default(false)
  canTakeTakeout   Boolean @default(true)
  canManageShifts  Boolean @default(false)

  // FASE 10 · RBAC GRANULAR — Permisos operativos especiales.
  // Estos refinan el rol genérico (WAITER/ADMIN/etc.) para casos donde
  // se necesita autorizar una operación sensible a empleados puntuales
  // sin promoverlos a un rol superior. Default false para principio de
  // mínimo privilegio: el admin tiene que activarlos explícitamente.
  canCancelItems    Boolean @default(false) // Anular productos ya enviados a cocina
  canApplyDiscounts Boolean @default(false) // Aplicar cortesías o descuentos al ticket
  canReopenTables   Boolean @default(false) // Reabrir una cuenta cerrada
  canManageUsers    Boolean @default(false) // Crear/editar otros empleados
  canViewExpectedCash Boolean @default(false) // Ver el efectivo esperado en el corte (rompe el corte ciego para este empleado)
  canManageDriverCash Boolean @default(false) // Recibir/cerrar el corte de los repartidores (caja del repartidor) sin ser admin

  shifts       EmployeeShift[]
  shiftsOpened CashShift[]     @relation("ShiftOpenedBy")
  shiftsClosed CashShift[]     @relation("ShiftClosedBy")
  taskLogs     TaskLog[]

  // FASE NÓMINA · perfil de pago (1:1) e histórico de renglones de raya
  payProfile   EmployeePayProfile?
  payrollItems PayrollItem[]
  charges      EmployeeCharge[]
  // Pagos de sueldo asignados a este empleado (gastos categoría SUELDOS).
  salaryPayments OperatingExpense[] @relation("EmployeeSalaryExpense")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeShift {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startAt    DateTime  @default(now())
  endAt      DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
}

// ═══════════════════════════════════════════════════════════════════════════
// FASE NÓMINA · Pago a empleados ("la raya"). Control interno por defecto; la
// capa fiscal (CFDI/IMSS) es OPCIONAL y se prende por restaurante con
// PayrollConfig.fiscalEnabled (sus columnas/flujo viven dormidas hasta entonces).
//
// Esquema de pago por defecto: POR DÍA TRABAJADO. Un día cuenta cuando el
// empleado tiene al menos un EmployeeShift (clock-in) ese día — las faltas se
// descuentan solas. El periodo de la raya es configurable en días.
//
// Dinero SIEMPRE en Decimal (regla del repo). Modelos tenant-scoped por
// restaurantId (van en SCOPED_MODELS) + locationId donde aplica.
// ═══════════════════════════════════════════════════════════════════════════

enum PayType {
  DAILY        // tarifa por día trabajado (default)
  HOURLY       // tarifa por hora (horas de EmployeeShift)
  WEEKLY_FIXED // sueldo fijo por periodo, sin importar días
  PER_DELIVERY // comisión por entrega (repartidores)
}

enum PayrollStatus {
  DRAFT    // borrador: calculada, editable
  APPROVED // aprobada, lista para pagar
  PAID     // pagada
}

enum TipPolicy {
  INDIVIDUAL   // cada quien se queda su propina
  POOL_BY_ROLE // pool repartido dentro de un rol
  POOL_ALL     // pool repartido entre todos
}

// Config de nómina por restaurante (1:1).
model PayrollConfig {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Largo del periodo de la raya, en días (configurable: 7, 14, 15...).
  periodLengthDays Int       @default(7)
  defaultPayType   PayType   @default(DAILY)
  tipPolicy        TipPolicy @default(INDIVIDUAL)
  currency         String    @default("MXN")

  // Capa fiscal OPCIONAL. Mientras esté en false la nómina es solo control
  // interno (sin CFDI/IMSS). Prenderla habilita el track fiscal (fase posterior).
  fiscalEnabled Boolean @default(false)

  // Descuento de empleado por DEFECTO (%) aplicado cuando un empleado consume
  // "a cuenta" desde el TPV. 0 = sin descuento. Se puede sobreescribir por
  // empleado (EmployeePayProfile.discountPct) o por venta (override del cajero).
  employeeDiscountPct Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payroll_config")
}

// Perfil de pago por empleado (1:1 con Employee). Solo se usa la tarifa del
// payType activo; las demás quedan disponibles para cambiar de esquema sin migrar.
model EmployeePayProfile {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  employeeId   String     @unique
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  payType         PayType @default(DAILY)
  dailyRate       Decimal @default(0) @db.Decimal(12, 2)
  hourlyRate      Decimal @default(0) @db.Decimal(12, 2)
  fixedAmount     Decimal @default(0) @db.Decimal(12, 2) // por periodo (WEEKLY_FIXED)
  perDeliveryRate Decimal @default(0) @db.Decimal(12, 2) // comisión por entrega

  // Descuento de empleado (%) propio de este empleado. null = usa el default
  // del PayrollConfig. Permite tarifas de consumo distintas (p.ej. gerente 100%,
  // cocinero 50%) sin tocar la config global.
  discountPct Decimal? @db.Decimal(5, 2)

  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@map("employee_pay_profiles")
}

// Corrida de nómina (la raya de un periodo) por sucursal.
model PayrollPeriod {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  periodFrom DateTime
  periodTo   DateTime
  status     PayrollStatus @default(DRAFT)
  notes      String?

  // Snapshot del total neto del último cálculo (listados sin recomputar).
  totalNet Decimal @default(0) @db.Decimal(12, 2)

  // Auditoría
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  paidById     String?
  paidAt       DateTime?

  items          PayrollItem[]
  settledCharges EmployeeCharge[] // cargos a cuenta liquidados en esta corrida
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([restaurantId])
  @@index([locationId, periodFrom])
  @@map("payroll_periods")
}

// Renglón por empleado dentro de una corrida. Snapshot de identidad y tarifa
// para conservar el histórico aunque el empleado cambie o se elimine.
model PayrollItem {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  periodId     String
  period       PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  // Empleado: SetNull al borrar para no perder el histórico. Nombre/rol en snapshot.
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  employeeName String
  role         String?

  payType    PayType @default(DAILY)
  daysWorked Int     @default(0)
  rate       Decimal @default(0) @db.Decimal(12, 2) // tarifa aplicada (snapshot)

  gross            Decimal @default(0) @db.Decimal(12, 2) // base del periodo (días×tarifa o según payType)
  tips             Decimal @default(0) @db.Decimal(12, 2) // Fase 3
  commission       Decimal @default(0) @db.Decimal(12, 2) // Fase 3
  additions        Decimal @default(0) @db.Decimal(12, 2) // bonos / ajustes +
  advancesDeducted Decimal @default(0) @db.Decimal(12, 2) // Fase 2 (anticipos)
  deductions       Decimal @default(0) @db.Decimal(12, 2) // faltas / otros -
  net              Decimal @default(0) @db.Decimal(12, 2)

  payMethod String? // CASH / TRANSFER (al pagar)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId, employeeId])
  @@index([restaurantId])
  @@index([periodId])
  @@index([employeeId])
  @@map("payroll_items")
}

enum EmployeeChargeType {
  CONSUMPTION // consumo a cuenta (pidió comida/producto desde el TPV)
  ADVANCE     // anticipo en efectivo (le adelantaron dinero de su sueldo)
  ADJUSTMENT  // ajuste manual (+ debe / − a favor) capturado por el admin
}

enum EmployeeChargeStatus {
  PENDING   // pendiente de descontar en una raya
  SETTLED   // ya descontado en una corrida pagada (settledPeriodId)
  CANCELLED // anulado antes de liquidarse
}

// Cargo contra la "caja"/cuenta de un empleado: lo que debe por consumo a
// cuenta o por anticipos. El saldo PENDING se descuenta automáticamente en su
// renglón de la raya (PayrollItem.advancesDeducted) y se marca SETTLED cuando
// esa corrida se paga. Modelo tenant-scoped (restaurantId → tenant-guard).
model EmployeeCharge {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String?
  location     Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Empleado: SetNull al borrar para no perder el histórico contable. El nombre
  // queda en snapshot (employeeName) igual que en PayrollItem.
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  employeeName String

  type   EmployeeChargeType   @default(CONSUMPTION)
  status EmployeeChargeStatus @default(PENDING)

  // Monto que el empleado DEBE (positivo). Para un ADJUSTMENT a favor del
  // empleado se permite negativo. El neto de la raya resta este monto.
  amount Decimal @db.Decimal(12, 2)

  // Solo CONSUMPTION: descuento de empleado aplicado a la orden (snapshot) y la
  // orden ligada (1:1). orderId es @unique: una orden genera a lo más un cargo.
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  orderId        String? @unique
  order          Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  note String?

  // Liquidación: la corrida de raya que lo descontó (al pagarla).
  settledPeriodId String?
  settledPeriod   PayrollPeriod? @relation(fields: [settledPeriodId], references: [id], onDelete: SetNull)
  settledAt       DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([restaurantId])
  @@index([employeeId, status])
  @@index([settledPeriodId])
  @@map("employee_charges")
}

model VariantTemplate {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name      String
  options   VariantTemplateOption[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@map("variant_templates")
}

model VariantTemplateOption {
  id         String          @id @default(cuid())
  templateId String
  template   VariantTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  price      Float           @default(0)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())

  @@map("variant_template_options")
}

model CashShift {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  employeeId   String
  employeeName String

  openedById String?
  openedBy   Employee? @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  closedById String?
  closedBy   Employee? @relation("ShiftClosedBy", fields: [closedById], references: [id])

  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  isOpen       Boolean   @default(true)
  openingFloat Float     @default(0)
  closingFloat Float?
  notes        String?

  // Cierre Ciego: cuando es true el cajero NO ve el efectivo esperado al
  // momento de cerrar. Solo declara su conteo y el sistema calcula la
  // diferencia (sobrante/faltante) en el reporte para el supervisor.
  blindClose   Boolean @default(false)
  // Snapshot del efectivo esperado calculado al cierre (sales en efectivo +
  // openingFloat - expenses). Null mientras el turno está abierto.
  expectedCash Float?

  totalCash     Float @default(0)
  totalCard     Float @default(0)
  totalTransfer Float @default(0)
  totalCourtesy Float @default(0)
  totalTips     Float @default(0)
  totalExpenses Float @default(0)
  // Ingresos de efectivo a caja durante el turno (cambio/feria que el cajero
  // mete a la gaveta y que NO viene de una venta). Suma al efectivo esperado.
  totalCashIn   Float @default(0)
  totalSales    Float @default(0)
  ordersCount   Int   @default(0)

  expenses                     ShiftExpense[]
  cashIns                      ShiftCashIn[]
  orders                       Order[]
  operatingExpensePayments     OperatingExpense[] @relation("OperatingExpenseCashShift")
  purchaseOrderPayments        PurchaseOrder[]    @relation("PurchaseOrderCashShift")
  // Espejo en la bóveda del ciclo de este turno: el fondo que salió al abrir,
  // el efectivo contado y los cobros digitales que entraron al cerrar.
  vaultMovements               VaultMovement[]

  @@map("cash_shifts")
}

// ShiftCashIn · ingreso de efectivo a la caja durante el turno (la contraparte
// de ShiftExpense). El cajero mete cambio/feria a la gaveta — efectivo que no
// proviene de una venta. Suma al efectivo esperado en el arqueo del cierre.
model ShiftCashIn {
  id          String    @id @default(cuid())
  shiftId     String
  shift       CashShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  category    String    @default("CHANGE")

  createdAt   DateTime  @default(now())

  @@index([shiftId])
  @@map("shift_cash_ins")
}

// ShiftExpense · cache/snapshot del gasto desde el punto de vista del
// CIERRE DE CAJA del turno. Es lo que el cajero ve en su corte. Cuando
// se paga con efectivo de caja (paymentMethod=CASH_DRAWER), creamos
// SIEMPRE una fila aquí Y una fila en Expense/PurchaseOrder.
// expenseId y purchaseOrderId permiten rastrear el documento contable
// que originó este movimiento de caja.
model ShiftExpense {
  id          String    @id @default(cuid())
  shiftId     String
  shift       CashShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  category    String    @default("OTHER")

  // Vínculo opcional al documento contable que originó este out de caja.
  // Exactamente uno de los dos (o ninguno para gastos legacy/manuales).
  operatingExpenseId String?
  operatingExpense   OperatingExpense? @relation(fields: [operatingExpenseId], references: [id])
  purchaseOrderId    String?
  purchaseOrder      PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])

  createdAt   DateTime  @default(now())

  @@index([operatingExpenseId])
  @@index([purchaseOrderId])
  @@map("shift_expenses")
}

// ═══════════════════════════════════════════════════════════════════════════
// BÓVEDA · el dinero del negocio que ya NO está en la gaveta del turno.
//
// El problema real: el dueño compra insumos en tiendas (Walmart, Sam's) con
// dinero que YA salió de la caja en días anteriores. Registrar esa compra
// como CASH_DRAWER descuadra el corte del cajero (baja el efectivo esperado
// sin que salga dinero de su gaveta). La bóveda es el tercer bolsillo, junto
// a la caja del turno y la caja del repartidor.
//
// Tiene DOS bolsas independientes (VaultChannel):
//   · CASH    → billetes: entra lo contado al cerrar caja, sale el fondo al abrir.
//   · DIGITAL → banco: entra lo cobrado con tarjeta/transferencia, sale lo que
//               se paga con tarjeta corporativa o transferencia.
// Nunca se mezclan: no puedes comprar con billetes que están en el banco.
//
// Invariantes:
//   · Un movimiento de bóveda NUNCA crea ShiftExpense ni toca CashShift.
//     El corte del cajero es independiente de los saldos de la bóveda.
//   · Vault.balanceCash/balanceDigital son cache; la verdad es la suma de
//     movimientos. Ambos se escriben en la MISMA $transaction (ver lib/vault.js).
//   · balanceAfter congela el saldo DE SU CANAL tras cada movimiento (auditoría).
//
// Ciclo del dinero:
//   abrir turno   → WITHDRAWAL(SHIFT_OPEN, CASH)     openingFloat (el fondo sale)
//   cerrar turno  → DEPOSIT(SHIFT_CLOSE, CASH)       closingFloat (lo contado entra)
//                 → DEPOSIT(SHIFT_CLOSE, DIGITAL)    totalCard + totalTransfer
//   compra/gasto  → WITHDRAWAL(EXPENSE|PURCHASE|SETTLEMENT) en su canal
//   ajustes       → DEPOSIT|WITHDRAWAL(MANUAL) en el canal elegido
// ═══════════════════════════════════════════════════════════════════════════

model Vault {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  // Una bóveda por sucursal. El dinero acumulado no se mezcla entre locales.
  locationId   String     @unique
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  balanceCash    Decimal @default(0) @db.Decimal(12, 2) // billetes fuera de la caja
  balanceDigital Decimal @default(0) @db.Decimal(12, 2) // saldo en banco/tarjeta

  movements VaultMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@map("vaults")
}

enum VaultMovementType {
  DEPOSIT    // entra dinero a la bóveda
  WITHDRAWAL // sale dinero de la bóveda
}

// En qué bolsa cae el movimiento. Un gasto pagado con tarjeta no puede salir
// de los billetes guardados, y viceversa.
enum VaultChannel {
  CASH    // efectivo acumulado
  DIGITAL // banco: tarjeta corporativa y transferencias
}

// De dónde vino el movimiento. SHIFT_OPEN/SHIFT_CLOSE son automáticos y
// idempotentes por turno y canal (@@unique([shiftId, source, channel])).
enum VaultSource {
  SHIFT_CLOSE // cierre de caja → entra (efectivo contado y/o cobros digitales)
  SHIFT_OPEN  // fondo de caja del turno nuevo → sale
  MANUAL      // depósito/retiro capturado a mano
  EXPENSE     // gasto operativo pagado desde la bóveda
  PURCHASE    // compra de insumos pagada desde la bóveda
  SETTLEMENT  // liquidación/abono de una cuenta por pagar
}

model VaultMovement {
  id           String     @id @default(cuid())
  vaultId      String
  vault        Vault      @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  type    VaultMovementType
  source  VaultSource
  channel VaultChannel

  amount       Decimal @db.Decimal(12, 2) // siempre positivo; el signo lo da `type`
  balanceAfter Decimal @db.Decimal(12, 2) // saldo del canal tras este movimiento

  description String
  notes       String?

  // Trazabilidad al documento que originó el movimiento. Como máximo uno.
  shiftId            String?
  shift              CashShift?        @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  operatingExpenseId String?
  operatingExpense   OperatingExpense? @relation(fields: [operatingExpenseId], references: [id], onDelete: SetNull)
  purchaseOrderId    String?
  purchaseOrder      PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  // Quién lo hizo. SIN FK a propósito: el TPV se autentica como Employee y el
  // admin como User — una FK a `users` devolvería 500 en cada captura de caja
  // (mismo bug que ya se corrigió en OperatingExpense.createdById).
  createdById   String?
  createdByName String?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  // Idempotencia del ciclo de turno: un turno deposita al cerrar y retira al
  // abrir EXACTAMENTE una vez POR CANAL (el cierre genera hasta dos depósitos:
  // efectivo y digital). Un replay del outbox offline no duplica saldo.
  // (Postgres permite múltiples NULL, así que no restringe los demás sources.)
  @@unique([shiftId, source, channel])
  @@index([vaultId, occurredAt])
  @@index([restaurantId, occurredAt])
  @@index([operatingExpenseId])
  @@index([purchaseOrderId])
  @@map("vault_movements")
}

model IntegrationConfig {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  type      String
  enabled   Boolean   @default(false)
  mode      String    @default("sandbox")
  config    String
  webhook   String?
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([restaurantId, type])
}

model ExternalOrder {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  platform   String
  externalId String
  orderId    String?
  rawData    String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// CHATBOT DE WHATSAPP — estado de la conversación de toma de pedidos.
//
// Persistimos el estado en DB (no en memoria) a propósito: el backend de
// Railway se reinicia en cada deploy a master, y una conversación a medias no
// debe perderse. Una sesión es única por (restaurantId, phone). El campo `data`
// guarda el "contexto" serializado (carrito, tipo de pedido, dirección,
// coordenadas, nombre, navegación del menú). `expiresAt` permite caducar
// conversaciones abandonadas (el job/lazy-cleanup las descarta).
// ─────────────────────────────────────────────────────────────────────────────
model WhatsappSession {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Número del cliente, normalizado a solo dígitos con código de país (ej. 521...).
  phone String

  // Estado de la máquina de estados (ver services/whatsapp-bot/engine.js).
  state String @default("GREETING")

  // Contexto serializado de la conversación (JSON).
  data String @default("{}")

  // Última orden creada desde esta conversación (para "repetir"/seguimiento).
  lastOrderId String?

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, phone])
  @@index([expiresAt])
  @@map("whatsapp_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM DE WHATSAPP — base de clientes para remarketing.
//
// Cada número que hace un pedido por el chatbot se registra/actualiza aquí
// (best-effort). Permite segmentar y enviar campañas (ofertas, recordatorios).
// `optIn` respeta el consentimiento: si el cliente pide salir, no se le manda
// más marketing.
// ─────────────────────────────────────────────────────────────────────────────
model WhatsappContact {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  phone           String
  name            String?
  optIn           Boolean   @default(true) // consentimiento de marketing
  orderCount      Int       @default(0)
  totalSpent      Float     @default(0)
  lastOrderAt     DateTime?
  lastContactedAt DateTime?
  tags            String    @default("[]") // JSON array de etiquetas

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, phone])
  @@index([restaurantId])
  @@map("whatsapp_contacts")
}

// ─────────────────────────────────────────────────────────────────────────────
// BANDEJA DE ENTRADA DE WHATSAPP — conversaciones y mensajes persistidos.
//
// A diferencia de WhatsappSession (estado efímero de la máquina de estados,
// TTL 6h), aquí se guarda el HISTORIAL: cada mensaje entrante del cliente y
// cada respuesta del bot o del dueño. Es lo que alimenta la bandeja de entrada
// del panel admin. `lastInboundAt` ancla la ventana de 24h de Meta (fuera de
// ella solo se puede contestar con plantilla aprobada, que aún no manejamos:
// el panel bloquea la respuesta libre). `status` gobierna el handoff humano:
// mientras esté en NEEDS_HUMAN el bot guarda los mensajes pero NO contesta —
// el dueño responde desde el panel y al marcar RESOLVED el bot retoma.
// ─────────────────────────────────────────────────────────────────────────────
model WhatsappConversation {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Número del cliente, normalizado a solo dígitos (mismo formato que WhatsappSession).
  phone String
  // Último nombre de perfil conocido (viene del webhook del proveedor).
  name  String?

  status String @default("OPEN") // OPEN | NEEDS_HUMAN | RESOLVED

  lastMessageAt    DateTime  @default(now())
  lastInboundAt    DateTime? // ancla de la ventana de 24h
  lastOutboundAt   DateTime?
  unreadCount      Int       @default(0) // entrantes no vistos en el panel
  needsHumanReason String? // por qué se escaló (comando del cliente, error del bot)
  escalatedAt      DateTime?

  messages WhatsappMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, phone])
  @@index([restaurantId, status, lastMessageAt])
  @@map("whatsapp_conversations")
}

model WhatsappMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Scope de tenant (columna plana, sin relación inversa para no inflar Restaurant).
  restaurantId String

  direction String @default("IN") // IN (cliente) | OUT (bot/dueño)
  type      String @default("text") // text | location | other
  body      String @default("")
  // Id del mensaje en el proveedor (solo entrantes) — dedupe de reintentos de webhook.
  waMessageId String?
  sentBy      String @default("BOT") // BOT | HUMAN (respuesta desde el panel)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([restaurantId, createdAt])
  @@map("whatsapp_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUGERENCIAS DE VENTA (UPSELL) — el chatbot ofrece un producto antes del
// checkout ("¿le agregas unas papas?") y se mide cuánto genera cada regla.
//
// El precio y nombre del producto sugerido NUNCA se guardan aquí: se resuelven
// contra el menú vivo al momento de ofrecer (misma fuente de verdad del bot;
// si el producto se desactiva, la regla simplemente no se ofrece). Métricas:
// offerCount/acceptCount/revenue se actualizan desde el flujo del bot.
// Dinero en Decimal (regla del repo). Tenant-scope por columna plana
// (sin relación inversa, patrón PromoGamePlay).
// ─────────────────────────────────────────────────────────────────────────────
model UpsellRule {
  id           String @id @default(cuid())
  restaurantId String

  name    String
  enabled Boolean @default(true)

  // Producto sugerido.
  menuItemId String
  variantId  String?

  // Disparador: ALWAYS (siempre) | CATEGORY (el carrito trae esa categoría) |
  // ITEM (el carrito trae ese producto). triggerId = categoryId o menuItemId.
  triggerType String  @default("ALWAYS")
  triggerId   String?
  minSubtotal Decimal @default(0) @db.Decimal(12, 2)

  // Primera línea del mensaje (opcional; si falta se usa el copy default).
  offerText String?

  // Métricas de rendimiento.
  offerCount  Int     @default(0)
  acceptCount Int     @default(0)
  revenue     Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, enabled])
  @@map("upsell_rules")
}

// Zona de entrega por polígono. Cuando RestaurantConfig.deliveryMode = ZONES,
// la coordenada del cliente (GPS del checkout / pin de WhatsApp) se prueba
// contra estos polígonos y se cobra la fee de la zona que la contiene. Si no
// cae en ninguna, el pedido queda fuera de cobertura (OUT_OF_RANGE). La lógica
// vive en lib/delivery-fee.js (fuente única para tienda web y bot).
model DeliveryZone {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name  String
  fee   Decimal @default(0) @db.Decimal(12, 2)
  color String  @default("#22c55e") // color del polígono en el mapa del admin

  // Vértices del polígono: array JSON de { lat, lng } en orden. Se cierra solo
  // (el último vértice conecta con el primero). Mínimo 3 puntos.
  polygon Json

  active Boolean @default(true)
  // En solapes gana la de menor priority (se evalúa primero). Empates: por id.
  priority Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, active, priority])
  @@map("delivery_zones")
}

// Reacción ("me gusta") de un cliente a un platillo en la tienda pública. El
// cliente es anónimo: se identifica por un id generado en su navegador
// (localStorage). El @@unique evita que un mismo navegador cuente doble; el
// conteo del platillo = número de reacciones. Es engagement, no dinero.
model DishReaction {
  id           String   @id @default(cuid())
  restaurantId String
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  // Id anónimo del navegador (no es un usuario autenticado).
  clientId String

  createdAt DateTime @default(now())

  @@unique([menuItemId, clientId])
  @@index([restaurantId, menuItemId])
  @@map("dish_reactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// JUEGOS PROMOCIONALES — "ruleta de premios" que amarra ventas.
//
// El dueño configura premios con peso (probabilidad). El chatbot juega por
// comando ("premio") o automáticamente tras un pedido (según `trigger`) y, si
// el cliente gana, emite un Coupon real reutilizando el sistema de cupones.
// `prizes` es JSON: [{ label, type:'PERCENTAGE'|'FIXED'|'NONE', value, weight,
//   minOrderAmount, expiresInDays }]. type NONE = "sigue participando".
// ─────────────────────────────────────────────────────────────────────────────
model PromoGame {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name          String
  enabled       Boolean @default(false)
  trigger       String  @default("ON_COMMAND") // ON_COMMAND | ON_ORDER
  prizes        String  @default("[]")
  maxPerContact Int     @default(1) // 0 = ilimitado

  plays PromoGamePlay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@map("promo_games")
}

model PromoGamePlay {
  id     String    @id @default(cuid())
  gameId String
  game   PromoGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // Scope de tenant (columna plana, sin relación inversa para no inflar Restaurant).
  restaurantId String
  phone        String
  prizeLabel   String
  couponId     String?

  createdAt DateTime @default(now())

  @@index([gameId])
  @@index([restaurantId, phone])
  @@map("promo_game_plays")
}

model PushSubscription {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  userId    String?
  orderId   String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
}

model MenuItemVariant {
  id          String   @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  recipes     Recipe[]
}

model MenuItemComplement {
  id          String   @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model DeliveryMessage {
  id         String   @id @default(cuid())
  orderId    String
  fromDriver Boolean  @default(false)
  message    String
  createdAt  DateTime @default(now())
}

model DriverCashMovement {
  id          String    @id @default(cuid())
  driverId    String
  type        String
  category    String
  amount      Float
  description String?
  photoUrl    String?
  orderId     String?
  approved    Boolean   @default(false)
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model DriverCashCut {
  id           String   @id @default(cuid())
  driverId     String
  driverName   String
  totalFloat   Float    @default(0) // fondo de cambio asignado por el admin
  totalIncome  Float    @default(0)
  totalExpense Float    @default(0)
  totalReturn  Float    @default(0)
  balance      Float    @default(0) // totalFloat + totalIncome - totalExpense - totalReturn
  movements    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
}

// Solicitud del repartidor para que el admin cierre su turno / haga el corte de
// caja. El repartidor no puede auto-aprobar su efectivo (por eso /cut es requireAdmin),
// así que sólo "avisa": crea una solicitud PENDING que el admin ve en
// /admin/caja-repartidores. Al hacer el corte la solicitud se marca RESOLVED.
model DriverShiftRequest {
  id           String    @id @default(cuid())
  restaurantId String
  locationId   String?
  driverId     String
  driverName   String
  balance      Float     @default(0) // snapshot del efectivo en mano al solicitar
  status       String    @default("PENDING") // PENDING, RESOLVED
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([restaurantId, status, createdAt])
  @@map("driver_shift_requests")
}

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String
  orderId   String?
  lat       Float
  lng       Float
  accuracy  Float?
  speed     Float? // km/h
  heading   Float? // dirección en grados
  createdAt DateTime @default(now())
}

model DriverRoute {
  id         String    @id @default(cuid())
  driverId   String
  driverName String
  orderId    String?
  startAt    DateTime  @default(now())
  endAt      DateTime?
  originLat  Float
  originLng  Float
  points     Int       @default(0)
  distance   Float     @default(0) // km aproximados
  trigger    String    @default("MANUAL") // MANUAL, ORDER_ASSIGNED
}

// Avisos del restaurante a los repartidores. driverId null = broadcast a todos
// los repartidores del restaurante. readBy guarda los driverIds que ya leyeron.
model DriverNotice {
  id            String   @id @default(cuid())
  restaurantId  String
  locationId    String?
  driverId      String?
  title         String?
  body          String
  createdById   String?
  createdByName String?
  readBy        String[] @default([])
  createdAt     DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@map("driver_notices")
}

model KdsItemStatus {
  id          String    @id @default(cuid())
  orderId     String
  orderItemId String
  station     String // KITCHEN, BAR, FRYER
  done        Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
}

model KdsMessage {
  id        String   @id @default(cuid())
  orderId   String
  station   String // estación que envía
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// LANDING CMS — singleton JSON blob, edited by SUPER_ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model LandingContent {
  id        String   @id @default("landing") // always "landing"
  content   Json
  updatedAt DateTime @updatedAt
  updatedBy String?
  updater   User?    @relation("LandingContentUpdater", fields: [updatedBy], references: [id])

  @@map("landing_content")
}

// ─────────────────────────────────────────────────────────────────────────────
// TPV REMOTE CONFIG — configuración servida al APK TPV en tiempo de ejecución.
// Permite mover comportamiento y branding por sucursal sin reconstruir el APK.
// ─────────────────────────────────────────────────────────────────────────────

model TpvRemoteConfig {
  id         String   @id @default(cuid())
  locationId String   @unique
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Nivel 1 — override de la URL del backend (null = usar el default baked del APK)
  apiUrl String?

  // Tipos de orden que la sucursal acepta (subset de DINE_IN / TAKEOUT / DELIVERY)
  allowedOrderTypes Json @default("[\"DINE_IN\",\"TAKEOUT\",\"DELIVERY\"]")

  // Segundos de inactividad antes de auto-bloquear la caja (0 = desactivado)
  lockTimeoutSec Int @default(0)

  // Color de acento del TPV (hex). Si null, usa el accent del Restaurant.
  accentColor String?

  // Expansión futura sin migrar schema
  extra Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tpv_remote_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGÍSTICA & FLOTA — vehículos, turnos (Ride) y gastos operativos (FASE 4).
// Gateado en UI por Tenant.hasDelivery. Entidades scopeadas por tenantId.
// ─────────────────────────────────────────────────────────────────────────────

enum VehicleType {
  MOTO
  CARRO
  BICI
}

enum ExpenseCategory {
  GASOLINA
  REFACCION
  PONCHADURA
  OTROS
}

model Vehicle {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String // ej. "Moto A"
  plate    String?
  type     VehicleType @default(MOTO)
  isActive Boolean     @default(true)

  rides Ride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("vehicles")
}

model Ride {
  id         String @id @default(cuid())
  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Nota: la .md menciona `userId`; en este codebase los repartidores son
  // Employee (no User), así que referenciamos Employee.id por consistencia
  // con el resto del stack (PIN login, CashShift, etc.). Se mantiene como
  // String sin FK dura para evitar bloquear borrado de empleados históricos.
  employeeId String

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  startTime    DateTime  @default(now())
  endTime      DateTime?
  startMileage Int?
  endMileage   Int?

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([vehicleId])
  @@index([employeeId])
  @@map("rides")
}

model Expense {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id], onDelete: SetNull)

  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  description String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([rideId])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────────────────
// DINE-IN — Mesas físicas + rondas de comanda para cuentas abiertas.
// Las tablas son del local (Location), no del restaurante padre: dos sucursales
// de la misma marca tienen layouts y números distintos.
// ─────────────────────────────────────────────────────────────────────────────

enum TableStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
}

enum PrinterConnection {
  NETWORK
  USB
  BLUETOOTH
}

model Table {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Zona (área) opcional dentro del local: "Terraza", "Barra", "Mostrador",
  // "Patio", etc. Cada negocio define las suyas desde el panel de
  // configuración del TPV. Nullable para mesas "sin zona" (mesas extra que se
  // sacan en días no contemplados, mesas heredadas, etc.).
  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  name     String // "Mesa 1", "Barra 3", "Terraza A"
  // Coordenadas del mapa editable del TPV. En la misma unidad que la UI del
  // planímetro (píxeles o % del canvas, según implemente el front). Default 0
  // para que mesas creadas por API sin layout no rompan.
  x        Float       @default(0)
  y        Float       @default(0)
  // Capacidad nominal (comensales por defecto). El TPV la usa para
  // pre-llenar el modal "Cuántos comensales" al iniciar una orden DINE_IN
  // y para validar que no se sobrepase de forma accidental. Default 4 que
  // es la mesa estándar en restaurantes mexicanos.
  capacity Int         @default(4)
  status   TableStatus @default(AVAILABLE)
  isActive Boolean     @default(true)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dos mesas dentro del mismo local no pueden llamarse igual.
  @@unique([locationId, name])
  @@index([locationId])
  @@index([zoneId])
  @@map("tables")
}

// Zona (área) configurable del salón: "Terraza", "Mostrador", "Barra",
// "Patio", etc. Cada Location define su propio set — un food truck tendrá
// solo "Mostrador" mientras que un restaurante con patio tendrá "Salón
// principal" + "Terraza". Las mesas pueden estar en una zona o sin zona.
model Zone {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name     String // visible al usuario, único dentro del local
  icon     String? // emoji u id de icono para el chip ("🌴", "🛋️"...)
  order    Int     @default(0) // orden de presentación en filtros/lista
  isActive Boolean @default(true)

  tables Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, name])
  @@index([locationId])
  @@map("zones")
}

model OrderRound {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // 1 = primera comanda, 2 = segunda ronda, etc. Único por orden.
  roundNumber     Int
  sentToKitchenAt DateTime @default(now())

  items OrderItem[]

  createdAt DateTime @default(now())

  @@unique([orderId, roundNumber])
  @@index([orderId])
  @@map("order_rounds")
}

// ─────────────────────────────────────────────────────────────────────────────
// TAX CONFIG — impuestos y propinas configurables por sucursal.
// Soporta múltiples impuestos simultáneos (IVA + IEPS) y categorías
// (alcohol grava IEPS, comida no, etc.). Adaptable a normativa MX/LATAM.
// ─────────────────────────────────────────────────────────────────────────────

enum TaxType {
  VAT // IVA
  EXCISE // IEPS / impuestos especiales
  SERVICE_CHARGE // Cargo por servicio fijo
  TIP_SUGGESTION // Propina sugerida (no obligatoria)
}

model TaxConfig {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name        String // "IVA", "IEPS Alcohol", "Propina sugerida"
  type        TaxType
  rate        Float // 16.0 = 16%
  isInclusive Boolean @default(true) // true = ya incluido en el precio mostrado
  appliesTo   String  @default("ALL") // ALL | FOOD | BEVERAGES | ALCOHOL
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@map("tax_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCESS LOG — auditoría de operaciones sensibles per-tenant.
// Se diferencia de SaasLog (que es global, super-admin only) en que este vive
// dentro del tenant para ver "quién canceló esa orden, quién aplicó ese
// descuento, quién forzó el cierre del turno".
// ─────────────────────────────────────────────────────────────────────────────

model AccessLog {
  id           String  @id @default(cuid())
  tenantId     String
  restaurantId String?
  locationId   String?

  // Identidad del actor. Puede ser Employee (PIN) o User (email).
  actorType String // "EMPLOYEE" | "USER" | "SYSTEM"
  actorId   String?
  actorName String?

  // Acción ejecutada
  action   String // "ORDER_CANCEL" | "ORDER_DISCOUNT" | "ITEM_DELETE" | "PRICE_OVERRIDE" | "REFUND" | "SHIFT_FORCE_CLOSE"
  resource String? // referencia legible: "order:cl123" | "orderItem:abc"

  // Snapshot de cambio
  before Json?
  after  Json?
  reason String? // motivo dado por el actor (ej. "cliente cambió de opinión")

  ipAddress String?
  userAgent String?
  correlationId String?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([restaurantId])
  @@index([correlationId])
  @@map("access_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// HARDWARE PROVISIONING
// ─────────────────────────────────────────────────────────────────────────────

model Device {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name        String
  type        String // "POS", "KDS", "WAITER"
  deviceToken String    @unique
  isActive    Boolean   @default(true)
  lastPingAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([tenantId])
  @@map("devices")
}

// ─────────────────────────────────────────────────────────────────────────────
// GAMIFICACIÓN KDS
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  type         String
  pointsReward Int     @default(10)
  frequency    String?
  isActive     Boolean @default(true)

  logs TaskLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@map("tasks")
}

model TaskLog {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  pointsEarned Int
  completedAt  DateTime @default(now())
  notes        String?

  @@index([employeeId])
  @@index([taskId])
  @@map("task_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// OBSERVABILIDAD — Errores y eventos críticos del backend
// ─────────────────────────────────────────────────────────────────────────────

model SystemLog {
  id        String   @id @default(cuid())
  level     String // INFO | WARN | ERROR | CRITICAL
  message   String
  stack     String?
  path      String?
  method    String?
  tenantId  String?
  // Metadata libre serializada como JSON: ip, userId, deviceId, restaurantId,
  // requestId, etc. Mantener en JSON evita tener que migrar el schema cada
  // vez que un handler quiera agregar contexto.
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([tenantId])
  @@index([createdAt])
  @@map("system_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// OTA — bundles del web payload del TPV (Capacitor live updates).
// Cada release del TPV sube un zip a Supabase Storage y registra metadata acá.
// El plugin @capgo/capacitor-updater consulta /api/ota/check y descarga el
// bundle si la versión es mayor que la instalada.
// ─────────────────────────────────────────────────────────────────────────────
model OtaBundle {
  id          String   @id @default(cuid())
  appId       String   @default("com.mrtpvrest.tpv")
  version     String
  channel     String   @default("production")
  storagePath String
  checksum    String
  sizeBytes   Int
  notes       String?
  isActive    Boolean  @default(true)
  minNative   String?
  createdAt   DateTime @default(now())

  @@unique([appId, channel, version])
  @@index([appId, channel, isActive, createdAt])
  @@map("ota_bundles")
}

// ═══════════════════════════════════════════════════════════════════════════
// FASE INVENTARIO / COSTEO / RECETAS
// Diseñado a partir del Excel real de Eduardo (Costeo de recetas — USD).
// Convenciones:
//   - Recetas → restaurantId (compartidas entre sucursales)
//   - Stock / Movimientos / Compras → locationId (cada sucursal su libro)
//   - Snapshot de costo al cobrar en OrderItem.costSnapshot (NO recalcular
//     reportes históricos cuando suban precios de ingredientes)
//   - Unidad base normalizada (g/ml/pieza) — Kg y L se convierten a g/ml
// ═══════════════════════════════════════════════════════════════════════════

enum IngredientBaseUnit {
  GRAM
  ML
  PIECE
}

// ── Taxonomía referenciable ──────────────────────────────────────────────
// 4 TIPOS (estación operativa) × 10 CATEGORIAS (familia merchandise).
// Tabla en lugar de enum: cada restaurante puede agregar las suyas.

model IngredientType {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String // "BARRA", "COCINA", "DOMICILIOS", "INSUMOS"
  isActive     Boolean      @default(true)
  ingredients  Ingredient[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("ingredient_types")
}

model IngredientCategory {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String // "PROTEINAS", "LACTEOS Y DERIVADOS", ...
  color        String? // hex para agrupar en reportes de gasto
  isActive     Boolean      @default(true)
  ingredients  Ingredient[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("ingredient_categories")
}

// ── Multi-supplier con historial de precios ──────────────────────────────
// La relación 1:1 Ingredient.supplierId se conserva como "default supplier".
// Esta tabla permite múltiples proveedores con vigencia de precio.

model IngredientSupplier {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  purchaseUnit String // "Caja de 24", "Bulto 25kg"
  purchaseQty  Float // cantidad por unidad de compra
  price        Float // precio en esa unidad
  validFrom    DateTime  @default(now())
  validTo      DateTime? // null = vigente
  isPreferred  Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([ingredientId, validFrom])
  @@index([supplierId])
  @@map("ingredient_suppliers")
}

// ── SubRecipe (Preparaciones base) ───────────────────────────────────────
// Salsa verde, mezcla de quesos, sal preparada para pollo, etc.
// Se preparan en lote y se usan en múltiples platos.

model SubRecipe {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Rendimiento esperado: de Xg de insumos crudos sale Yg de subreceta
  // (cocción, evaporación, descarte de huesos, etc.).
  yieldQty       Float // 800 (gramos resultantes)
  yieldUnit      IngredientBaseUnit // GRAM / ML / PIECE
  marginErrorPct Float              @default(0) // % de pérdida adicional durante prep

  // computed (en código): costPerYieldUnit = sum(items.cost) / yieldQty / (1 - marginErrorPct/100)

  items         SubRecipeItem[] @relation("SubRecipeItems")
  // Esta SubRecipe usada como item dentro de otra SubRecipe (anidación)
  usedAsNested  SubRecipeItem[] @relation("NestedSubRecipe")
  usedInRecipes RecipeItem[]
  usedInModifiers ModifierIngredient[]
  preparationSteps String[]        @default([])
  isPendingReview  Boolean         @default(false)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("subrecipes")
}

// SubRecipeItem · ítem dentro de una SubRecipe.
// Validación en código: exactamente UNO de {ingredientId, nestedSubRecipeId}.
model SubRecipeItem {
  id          String    @id @default(cuid())
  subRecipeId String
  subRecipe   SubRecipe @relation("SubRecipeItems", fields: [subRecipeId], references: [id], onDelete: Cascade)

  ingredientId      String?
  ingredient        Ingredient? @relation(fields: [ingredientId], references: [id])
  nestedSubRecipeId String?
  nestedSubRecipe   SubRecipe?  @relation("NestedSubRecipe", fields: [nestedSubRecipeId], references: [id])

  qty   Float
  unit  IngredientBaseUnit
  notes String?

  @@index([subRecipeId])
  @@index([ingredientId])
  @@index([nestedSubRecipeId])
  @@map("subrecipe_items")
}

// ── Recipe (Escandallo final) ────────────────────────────────────────────
// 1:1 opcional con MenuItem. Guarda metadatos de costeo + pricing canal.
// El precio que cobra el TPV sigue siendo MenuItem.price; aquí guardamos
// el precio "con domicilio" y la comisión de plataforma para reportes.

model Recipe {
  id           String     @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  // Escandallo por variante: NULL = receta base del platillo; con valor = receta
  // específica de esa variante (p.ej. Alambre 350gr Arrachera/Pollo/Res y Cerdo).
  variantId    String?
  variant      MenuItemVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Costeo
  marginErrorPct  Float  @default(0) // pérdida durante prep adicional al wastage por ingrediente
  targetMarginPct Float? // override del PricingPolicy si existe

  // Pricing canal (no reemplaza MenuItem.price)
  priceDelivery         Float? // precio para apps de delivery (Rappi/Didi)
  platformCommissionPct Float? // ej. 27 (Rappi)

  // computed:
  //   totalCost     = sum(items.computedCost)        // CMV
  //   priceDineIn   = MenuItem.price
  //   marginDineIn  = (priceDineIn - totalCost) / priceDineIn
  //   marginDeliv   = (priceDelivery - totalCost - priceDelivery*platformCommissionPct/100) / priceDelivery

  items     RecipeItem[]
  preparationSteps String[] @default([])
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([menuItemId, variantId])
  @@index([restaurantId])
  @@map("recipes")
}

// ── ModifierIngredient ───────────────────────────────────────────────────
// Consumo de inventario de un modificador/extra. Se mapea por NOMBRE a nivel
// restaurante (order_item_modifiers guarda el nombre), así una sola regla
// "Papas Gajo Extra → 150g papa" cubre el extra en todos los platillos.
// Un modificador puede consumir varios insumos/subrecetas (varias filas).
model ModifierIngredient {
  id             String             @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  ingredientId   String?
  ingredient     Ingredient?        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  subRecipeId    String?
  subRecipe      SubRecipe?         @relation(fields: [subRecipeId], references: [id], onDelete: Cascade)
  quantity       Float
  unit           IngredientBaseUnit @default(GRAM)
  wastagePercent Float              @default(0)
  createdAt      DateTime           @default(now())

  @@index([restaurantId, name])
  @@map("modifier_ingredients")
}

// ── PricingPolicy ────────────────────────────────────────────────────────
// Margen meta por categoría (o default del restaurante con categoryId=null).
// Recipe.targetMarginPct sobreescribe esto si está seteado.

model PricingPolicy {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  targetMarginPct Float // ej. 70 cocteles, 75 entradas, 65 fuertes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, categoryId])
  @@index([restaurantId])
  @@map("pricing_policies")
}

// ── StockMovement (libro mayor unificado) ────────────────────────────────
// Reemplaza el viejo InventoryMovement (que se deja vivo por backward compat
// mientras se migra orders.routes.js). Toda operación que altera stock
// produce 1+ filas aquí. Reportes de inventario = SUM(delta) por ingredientId.

enum StockMovementReason {
  PURCHASE // entrada por compra recibida
  SALE // salida por venta (auto-rebajado al cobrar)
  WASTE // merma registrada (relacionada con WasteLog)
  ADJUSTMENT // ajuste manual del manager
  TRANSFER_IN // recibido de otra sucursal
  TRANSFER_OUT // enviado a otra sucursal
  PREP_CONSUME // consumido al preparar una SubRecipe
  PREP_YIELD // generado al terminar una SubRecipe
  PHYSICAL_COUNT // ajuste por conteo físico
  RETURN // devolución a proveedor
}

model StockMovement {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  locationId   String
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  delta  Float // + entrada / - salida en baseUnit del ingrediente
  unit   IngredientBaseUnit
  reason StockMovementReason

  // FK polimórfica: refType ∈ 'order'|'purchaseOrder'|'wasteLog'|'physicalCount'|'subRecipe'|null
  refType String?
  refId   String?

  // Balance después de este movimiento — cache para no recalcular toda
  // la historia en cada consulta. Se llena en la misma tx que el insert.
  balanceAfter Float

  unitCostAtMove Float? // para valuación (FIFO o promedio móvil)
  userId         String?
  user           User?   @relation(fields: [userId], references: [id])
  notes          String?

  // Relación 1:1 opcional con WasteLog (cuando reason=WASTE)
  wasteLog WasteLog?

  createdAt DateTime @default(now())

  @@index([ingredientId, createdAt])
  @@index([locationId, createdAt])
  @@index([refType, refId])
  @@map("stock_movements")
}

// ── WasteLog (detalle de mermas) ─────────────────────────────────────────
// Cada WasteLog tiene 1 StockMovement con reason=WASTE.

enum WasteReason {
  EXPIRED
  DAMAGED
  COURTESY
  OVERPREP
  CONTAMINATION
  STAFF_MEAL
  TEST_KITCHEN
  OTHER
}

model WasteLog {
  id              String        @id @default(cuid())
  stockMovementId String        @unique
  stockMovement   StockMovement @relation(fields: [stockMovementId], references: [id], onDelete: Cascade)

  reason       WasteReason
  reasonDetail String?
  photoUrl     String?

  approvedByUserId String?
  approvedByUser   User?   @relation("WasteApprovedBy", fields: [approvedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@map("waste_logs")
}

// ── PurchaseOrder + recepción ────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  poNumber    String // PO-2026-0001
  status      PurchaseOrderStatus @default(DRAFT)
  expectedAt  DateTime?
  receivedAt  DateTime?
  totalAmount Float               @default(0)
  notes       String?

  // Método de pago. Si CASH_DRAWER, también se crea un ShiftExpense
  // vinculado al cashShiftId para que el cierre de caja cuadre.
  paymentMethod ExpensePaymentMethod @default(TRANSFER)
  cashShiftId   String?  // turno donde se pagó (solo cuando CASH_DRAWER)
  cashShift     CashShift? @relation("PurchaseOrderCashShift", fields: [cashShiftId], references: [id])

  // ── Cuentas por pagar (ver OperatingExpense / SettlementStatus) ──
  // PENDING ⇒ la mercancía se recibe (sube stock) pero el pago queda a deber:
  // NO crea ShiftExpense hasta liquidarse vía POST /api/purchases/:id/settle.
  settlementStatus SettlementStatus     @default(PAID)
  paidAmount       Float                @default(0)  // abonos acumulados (pagos parciales)
  dueDate          DateTime?
  settledAt        DateTime?
  settledShiftId   String?
  settledMethod    ExpensePaymentMethod?

  items       PurchaseOrderItem[]
  shiftExpenses ShiftExpense[]   // 1:N (en teoría siempre 1 cuando es CASH_DRAWER)
  vaultMovements VaultMovement[]  // 1:N (cuando se paga desde la bóveda)
  createdById String?
  createdBy   User?               @relation(fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([locationId, poNumber])
  @@index([locationId, status])
  @@index([supplierId])
  @@index([cashShiftId])
  @@index([settlementStatus])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])

  qtyOrdered  Float // en purchaseUnit
  qtyReceived Float @default(0)
  unitPrice   Float
  lineTotal   Float @default(0)

  @@index([purchaseOrderId])
  @@index([ingredientId])
  @@map("purchase_order_items")
}

// ── PhysicalCount (conteo físico) ────────────────────────────────────────

model PhysicalCount {
  id          String              @id @default(cuid())
  locationId  String
  location    Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  startedAt   DateTime            @default(now())
  closedAt    DateTime?
  status      String              @default("OPEN") // OPEN | CLOSED
  createdById String?
  createdBy   User?               @relation(fields: [createdById], references: [id])
  items       PhysicalCountItem[]
  notes       String?

  @@index([locationId, startedAt])
  @@map("physical_counts")
}

model PhysicalCountItem {
  id              String        @id @default(cuid())
  physicalCountId String
  physicalCount   PhysicalCount @relation(fields: [physicalCountId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])

  expectedQty Float // lo que el sistema decía antes del conteo
  countedQty  Float // lo que el staff contó físicamente
  // delta = countedQty - expectedQty → se persiste como StockMovement
  // con reason=PHYSICAL_COUNT al cerrar el conteo.

  notes String?

  @@index([physicalCountId])
  @@index([ingredientId])
  @@map("physical_count_items")
}

// ── StockTransfer · reparto de Bodega Central → sucursales ───────────────
//
// Sólo se usa cuando RestaurantConfig.centralWarehouseEnabled = true.
// Un reparto crea, en una sola transacción, por cada línea:
//   1. StockMovement TRANSFER_OUT en la Bodega Central (delta negativo)
//   2. StockMovement TRANSFER_IN  en la sucursal destino (delta positivo)
//   3. Ingredient.stock -= qty (central)  /  += qty (sucursal destino)
//   4. StockTransferItem (detalle auditable)
// El stock total del restaurant se conserva: lo que sale de central entra
// en las sucursales. Las recetas siguen descontando del stock por sucursal.
enum StockTransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model StockTransfer {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  fromLocationId String
  fromLocation   Location @relation("TransferFromLocation", fields: [fromLocationId], references: [id], onDelete: Cascade)

  status    StockTransferStatus @default(COMPLETED)
  notes     String?
  totalCost Float               @default(0)

  items StockTransferItem[]

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([restaurantId, createdAt])
  @@index([fromLocationId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id              String        @id @default(cuid())
  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)

  // Ingrediente origen (la fila del catálogo de la Bodega Central).
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  toLocationId String
  toLocation   Location @relation("TransferToLocation", fields: [toLocationId], references: [id], onDelete: Cascade)

  qty            Float
  unitCostAtMove Float?

  @@index([stockTransferId])
  @@index([ingredientId])
  @@index([toLocationId])
  @@map("stock_transfer_items")
}

// ── RETAIL CORE · tiendas de ropa / SKU exacto ─────────────────────────────
//
// Este bloque es deliberadamente paralelo al dominio restaurante. El prototipo
// "Ropa Santo Tomás" mostró que MenuItem+Ingredient sirve como demo, pero no
// como base productiva para talla/color/SKU/offline. Retail usa su propio
// catálogo, existencias, ventas, traspasos y outbox.

enum RetailSaleStatus {
  COMPLETED
  CANCELLED
  PARTIAL_RETURN
  RETURNED
}

enum RetailPaymentMethod {
  CASH
  CARD_PRESENT
  TRANSFER
  COURTESY
}

enum RetailTransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum RetailStockMovementReason {
  PURCHASE
  SALE
  RETURN
  CANCEL
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  PHYSICAL_COUNT
}

enum RetailOutboxStatus {
  PENDING
  APPLIED
  FAILED
}

model RetailProduct {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  brand       String?
  category    String?
  gender      String?
  season      String?
  imageUrl    String?
  isActive    Boolean @default(true)

  skus     RetailSku[]
  fitments RetailFitment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, isActive])
  @@index([restaurantId, category])
  @@map("retail_products")
}

model RetailSku {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  productId    String
  product      RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku     String
  barcode String?
  // Atributos genéricos. NO son "talla/color" salvo en el giro ROPA: cada giro
  // los reetiqueta (ferretería: size=Medida, style=Rosca; refaccionaria:
  // size=Posición, style=Lado). El mapeo vive en apps/moda/src/lib/giro.ts.
  size     String?
  color    String?
  material String?
  style    String?
  price    Decimal @db.Decimal(12, 2)
  cost     Decimal @default(0) @db.Decimal(12, 2)
  imageUrl String?
  isActive Boolean @default(true)

  // ── Inventario genérico (Fase 1 · retail multigiro) ────────────────────────
  // Unidad de venta: PZA | MTS | KG | LTS | CAJA. Las cantidades ya son
  // Decimal(12,3) en stock/movimientos/líneas, así que el granel (cable por
  // metro, tornillos por kilo) no necesita cambio de tipos.
  unitOfMeasure   String   @default("PZA")
  // Conversión caja↔pza al vender/recibir. Null = no aplica.
  unitsPerPackage Decimal? @db.Decimal(12, 3)
  // Ubicación física en almacén (pasillo/anaquel/bin).
  binLocation     String?
  // Proveedor por SKU. Texto libre: no hay tabla de proveedores en retail aún.
  supplierRef     String?

  stockBalances RetailStockByLocation[]
  movements     RetailStockMovement[]
  saleLines     RetailSaleLine[]
  transferItems RetailTransferItem[]
  priceTiers    RetailPriceTier[]
  priceListItems RetailPriceListItem[]
  crossRefs     RetailCrossRef[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, sku])
  @@unique([restaurantId, barcode])
  @@index([productId])
  @@index([restaurantId, isActive])
  @@map("retail_skus")
}

model RetailStockByLocation {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String
