enum RetailShiftStatus {
  OPEN
  CLOSED
}

enum RetailCashMovementType {
  CASH_IN
  CASH_OUT
  EXPENSE
}

// Turno/caja de la tienda retail. Equivalente al CashShift del restaurante pero
// tenant-scoped (restaurantId) y en Decimal. Una sola caja ABIERTA por sucursal
// a la vez. Las ventas retail se enlazan a la caja abierta (shiftId) para cuadrar
// el corte: esperado = openingFloat + ventas en efectivo + entradas - salidas.
model RetailCashShift {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  deviceId     String?
  device       RetailDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  openedById   String?
  openedByName String?
  closedById   String?

  status   RetailShiftStatus @default(OPEN)
  openedAt DateTime          @default(now())
  closedAt DateTime?

  openingFloat Decimal  @default(0) @db.Decimal(12, 2)
  countedCash  Decimal? @db.Decimal(12, 2)
  // Corte ciego: el cajero declara su conteo sin ver el esperado. El esperado y
  // la diferencia se calculan al cierre (null mientras la caja está abierta).
  expectedCash Decimal? @db.Decimal(12, 2)
  difference   Decimal? @db.Decimal(12, 2)
  blindClose   Boolean  @default(false)

  // Snapshots denormalizados al cierre (para el reporte, sin recomputar).
  totalCashSales     Decimal @default(0) @db.Decimal(12, 2)
  totalCardSales     Decimal @default(0) @db.Decimal(12, 2)
  totalTransferSales Decimal @default(0) @db.Decimal(12, 2)
  totalCashIn        Decimal @default(0) @db.Decimal(12, 2)
  totalCashOut       Decimal @default(0) @db.Decimal(12, 2)
  salesCount         Int     @default(0)
  notes              String?

  sales     RetailSale[]
  movements RetailCashMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, status])
  @@index([locationId, status])
  @@map("retail_cash_shifts")
}

model RetailCashMovement {
  id      String          @id @default(cuid())
  shiftId String
  shift   RetailCashShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  type        RetailCashMovementType
  amount      Decimal @db.Decimal(12, 2)
  reason      String?
  category    String?
  createdById String?

  createdAt DateTime @default(now())

  @@index([shiftId])
  @@map("retail_cash_movements")
}

// ═══════════════════════════════════════════════════════════════════════════
// RETAIL MULTIGIRO · ferretería y refaccionaria
// Ver docs/plan-retail-multigiro.md. Todos con restaurantId ⇒ van en
// SCOPED_MODELS de packages/database/tenant-guard.js (tenant-guard.test.js
// falla si se olvida).
// ═══════════════════════════════════════════════════════════════════════════

/// Lista de precios por tipo de cliente: "Público", "Contratista", "Mayoreo".
///
/// Es ORTOGONAL a RetailPriceTier: la lista depende de QUIÉN compra, el tier de
/// CUÁNTO lleva. Cuando ambos aplican gana el más barato para el cliente — ver
/// `priceFor` en retail.routes.js y su espejo `unitPriceFor` en moda/lib/retail.ts.
/// Sin esa regla, un contratista que compra volumen podría terminar pagando MÁS
/// que el público, que es justo lo que nadie espera de un mostrador.
model RetailPriceList {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name String
  /// La que el POS preselecciona. No hay unique parcial en Prisma; el backend
  /// garantiza que solo una quede en true por restaurante.
  isDefault Boolean @default(false)
  sortOrder Int     @default(0)

  items RetailPriceListItem[]
  sales RetailSale[]

  createdAt DateTime @default(now())

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("retail_price_lists")
}

/// Precio de un SKU dentro de una lista. Si un SKU no tiene fila aquí, esa lista
/// usa su precio de catálogo (RetailSku.price) — así una lista nueva no obliga a
/// capturar los cientos de SKUs que no cambian de precio.
model RetailPriceListItem {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  priceListId String
  priceList   RetailPriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  skuId       String
  sku         RetailSku       @relation(fields: [skuId], references: [id], onDelete: Cascade)

  price Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@unique([priceListId, skuId])
  @@index([restaurantId])
  @@index([skuId])
  @@map("retail_price_list_items")
}

/// Precio por volumen (mayoreo). Ferretería/refaccionaria: "de 100 pzas en
/// adelante, a $X". El tier aplicable lo resuelve SIEMPRE el backend al armar la
/// línea de venta (dinero server-side): el cliente nunca manda precio.
model RetailPriceTier {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  skuId        String
  sku          RetailSku  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  /// Cantidad mínima para que aplique el precio. Decimal(12,3) como el resto de
  /// las cantidades: permite tiers de granel (a partir de 2.5 kg).
  minQty Decimal @db.Decimal(12, 3)
  /// Precio unitario a partir de minQty. Decimal, nunca Float ni @db.Money.
  price  Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  /// Un solo precio por (sku, minQty): dos tiers con el mismo mínimo harían la
  /// resolución dependiente del orden de inserción.
  @@unique([skuId, minQty])
  @@index([skuId, minQty])
  @@index([restaurantId])
  @@map("retail_price_tiers")
}

/// Compatibilidad marca-modelo-año (fitment). Refaccionaria: "esta balata entra
/// en Nissan Versa 2012-2019". Cuelga del PRODUCTO, no del SKU: la compatibilidad
/// es del artículo, no de su presentación.
model RetailFitment {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  productId    String
  product      RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  make     String
  model    String?
  yearFrom Int?
  yearTo   Int?
  engine   String?

  createdAt DateTime @default(now())

  @@index([restaurantId, make, model])
  @@index([productId])
  @@map("retail_fitments")
}

/// Equivalencias / cross-reference de número de parte. Refaccionaria: el cliente
/// llega con el número de otra marca y hay que resolver a nuestro SKU.
model RetailCrossRef {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  skuId        String
  sku          RetailSku  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  brand      String?
  partNumber String

  createdAt DateTime @default(now())

  /// La misma parte de la misma marca no se registra dos veces para un SKU.
  @@unique([skuId, brand, partNumber])
  @@index([restaurantId, partNumber])
  @@map("retail_cross_refs")
}


// ═══════════════════════════════════════════════════════════════════════════
// FASE COMPRAS / GASTOS · captura desde TPV (foto del ticket o manual)
//
// Reglas operativas:
//   · paymentMethod=CASH_DRAWER → AUTOMÁTICAMENTE se crea un ShiftExpense
//     vinculado al cashShiftId activo para que el corte de caja del cajero
//     cuadre perfecto. Se valida que exista turno abierto antes de aceptar.
//   · paymentMethod=CASH_VAULT → sale de la bolsa de efectivo de la bóveda.
//   · paymentMethod=CORPORATE_CARD | TRANSFER → sale de la bolsa digital de
//     la bóveda (el dinero estaba en el banco). Ninguno de los tres afecta la
//     caja del turno ni exige turno abierto. Ver `model Vault`.
//   · Compras de inventario van en PurchaseOrder + StockMovement(PURCHASE).
//     Gastos generales (luz, agua, sueldos, propinas pagadas) van en Expense.
//   · Para compras pagadas con efectivo de caja, PurchaseOrder.cashShiftId
//     se setea y también se crea un ShiftExpense (category=PURCHASE,
//     description="Compra: <supplier>").
// ═══════════════════════════════════════════════════════════════════════════

// Cómo se pagó. Solo CASH_DRAWER toca el corte del cajero; los otros tres
// salen de la bóveda (ver model Vault): CASH_VAULT de la bolsa de efectivo,
// CORPORATE_CARD y TRANSFER de la bolsa digital.
enum ExpensePaymentMethod {
  CASH_DRAWER       // efectivo de caja (rebaja CashShift via ShiftExpense)
  CASH_VAULT        // efectivo acumulado del negocio (rebaja Vault.balanceCash)
  CORPORATE_CARD    // tarjeta corporativa (rebaja Vault.balanceDigital)
  TRANSFER          // transferencia bancaria (rebaja Vault.balanceDigital)
}

// Estado de liquidación de un gasto/compra (cuentas por pagar).
//   PAID    → ya pagado (comportamiento histórico y default).
//   PENDING → deuda registrada que NO toca caja todavía: no crea ShiftExpense
//             ni descuenta efectivo. Solo al liquidar (POST /settle) golpea la
//             caja del día en que realmente se paga.
enum SettlementStatus {
  PAID
  PENDING
}

// ── OperatingExpenseCategory · taxonomía referenciable de gastos del local
// Sembradas al crear restaurant. Cada restaurant puede agregar las suyas.
// Default: LUZ, AGUA, INTERNET, GAS, MANTENIMIENTO, SUELDOS,
// PROPINAS_PAGADAS, OTROS.
//
// Nota: el enum ExpenseCategory de Logística (GASOLINA/REFACCION/...) es
// otro concepto — no confundir. Aquí es taxonomía libre por tenant.
model OperatingExpenseCategory {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name         String       // "LUZ", "AGUA", "SUELDOS", etc.
  icon         String?      // emoji / icon name (UI hint)
  color        String?      // hex para reportes
  isActive     Boolean      @default(true)
  expenses     OperatingExpense[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("operating_expense_categories")
}

// ── OperatingExpense · gasto operativo del local (NO inventario) ─────────
// Para compras de inventario usar PurchaseOrder. Este modelo es para
// gastos como luz/agua/sueldos/propinas pagadas en efectivo/etc., capturados
// desde el TPV con foto del ticket o manual.
model OperatingExpense {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  categoryId String?
  category   OperatingExpenseCategory? @relation(fields: [categoryId], references: [id])

  concept       String                // descripción libre ("Pago CFE bimestre Mayo")
  amount        Float                 // monto en moneda local
  paymentMethod ExpensePaymentMethod
  occurredAt    DateTime              @default(now())

  // ── Cuentas por pagar ──
  // PENDING ⇒ deuda que NO toca caja hasta liquidarse (ver SettlementStatus).
  settlementStatus SettlementStatus     @default(PAID)
  paidAmount       Float                @default(0)  // abonos acumulados (pagos parciales)
  supplierId       String?
  supplier         Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  dueDate          DateTime?
  settledAt        DateTime?
  settledShiftId   String?              // turno donde se liquidó (si fue CASH_DRAWER)
  settledMethod    ExpensePaymentMethod?

  // ── Pago de sueldo (nómina simple) ──
  // Cuando categoría=SUELDOS y el pago se asigna a un trabajador: liga el gasto
  // al empleado y guarda el detalle del cálculo (días × tarifa) para el reporte
  // por trabajador. Null en gastos que no son sueldos. onDelete SetNull: el
  // registro histórico del pago sobrevive si el empleado se elimina.
  employeeId  String?
  employee    Employee? @relation("EmployeeSalaryExpense", fields: [employeeId], references: [id], onDelete: SetNull)
  payrollDays Float?    // días pagados (capturados/editables al pagar)
  payrollRate Float?    // tarifa diaria aplicada al momento del pago

  // Si paymentMethod=CASH_DRAWER, el turno activo donde se descontó.
  cashShiftId String?
  cashShift   CashShift? @relation("OperatingExpenseCashShift", fields: [cashShiftId], references: [id])
  shiftExpenses ShiftExpense[]   // 1:N (siempre 1 cuando es CASH_DRAWER)
  vaultMovements VaultMovement[]  // 1:N (cuando se paga desde la bóveda)

  // Adjuntos / metadata
  photoUrl    String?               // foto del ticket/recibo
  notes       String?

  // Auditoría
  createdById String?
  createdBy   User?      @relation(fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([restaurantId])
  @@index([locationId, occurredAt])
  @@index([categoryId])
  @@index([cashShiftId])
  @@index([settlementStatus])
  @@index([supplierId])
  @@index([employeeId])
  @@map("operating_expenses")
}

// Plantilla de gasto recurrente (renta, luz, sueldos): el generador
// (POST /api/payables/recurring/run, idealmente por cron diario) materializa
// una cuenta por pagar (OperatingExpense PENDING) cada periodo y avanza
// nextDueAt. Sin relaciones formales para acotar el cambio de schema; los ids
// se resuelven en la capa de ruta. Está en SCOPED_MODELS (tiene restaurantId).
model RecurringExpense {
  id              String    @id @default(cuid())
  restaurantId    String
  locationId      String?
  categoryId      String?
  supplierId      String?
  concept         String
  amount          Float
  frequency       String    @default("MONTHLY") // MONTHLY | BIWEEKLY | WEEKLY
  dayOfMonth      Int?       // ancla para MONTHLY (1-28)
  nextDueAt       DateTime
  lastGeneratedAt DateTime?
  isActive        Boolean   @default(true)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([restaurantId, isActive])
  @@map("recurring_expenses")
}

// ---------------------------------------------------------------------------
// Panel interno de clientes SaaS (tablas `admin_*`)
//
// Creadas el 2026-07-09 directamente contra Supabase (migraciones
// `admin_panel_clientes` y `admin_daily_reports` en supabase_migrations), sin
// pasar por Prisma. Se adoptan aquí para que `migrate diff` deje de proponer
// su DROP. Son de la plataforma, no de un restaurante: se scopean por tenantId,
// NO por restaurantId, así que quedan fuera de SCOPED_MODELS del tenant-guard.
//
// Usan `timestamptz` porque así se crearon (el resto del schema usa
// `timestamp(3)`); respetarlo mantiene el diff contra producción vacío.
// ---------------------------------------------------------------------------

/// Checklist de onboarding por tenant. `id` es determinístico: "<tenantId>_<stepKey>".
model AdminOnboardingTask {
  id        String    @id
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category  String // marca | menu | config | lanzamiento
  stepKey   String    @map("step_key")
  label     String
  sortOrder Int       @default(0) @map("sort_order")
  done      Boolean   @default(false)
  doneAt    DateTime? @map("done_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, stepKey])
  @@index([tenantId], map: "idx_aot_tenant")
  @@map("admin_onboarding_tasks")
}

/// Plantillas de mensajes que el equipo manda a los clientes durante el onboarding.
model AdminMessageTemplate {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  title     String
  category  String?
  body      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("admin_message_templates")
}

/// Notas libres del equipo sobre un cliente.
model AdminClientNote {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  note      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_acn_tenant")
  @@map("admin_client_notes")
}

/// Resumen diario de la plataforma (altas de las últimas 24h + texto).
model AdminDailyReport {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  reportDate DateTime @default(dbgenerated("CURRENT_DATE")) @map("report_date") @db.Date
  new24h     Int      @default(0) @map("new_24h")
  summary    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "idx_adr_date")
  @@map("admin_daily_reports")
}
