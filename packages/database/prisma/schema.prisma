model RetailSale {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  deviceId     String?
  device       RetailDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  shiftId      String?
  shift        RetailCashShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  clientSaleId String
  folio        String
  status       RetailSaleStatus @default(COMPLETED)

  subtotal Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  tax      Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  customerName  String?
  customerPhone String?
  notes         String?
  createdById   String?
  syncedAt      DateTime?

  /// Lista de precios con la que se cobró. Se guarda para poder explicar DESPUÉS
  /// por qué un ticket salió a cierto precio: sin esto, un total de contratista
  /// es indistinguible de un descuento no autorizado.
  /// SetNull: borrar una lista no debe borrar el histórico de ventas.
  priceListId String?
  priceList   RetailPriceList? @relation(fields: [priceListId], references: [id], onDelete: SetNull)

  lines    RetailSaleLine[]
  payments RetailPayment[]

