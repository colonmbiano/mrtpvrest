{
  "name": "@mrtpvrest/moda",
  "version": "1.0.7",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3012 --webpack",
    "build": "next build",
    "start": "next start -p 3012",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "build:apk": "cross-env CAPACITOR_BUILD=true next build && npx cap sync android",
    "apk:debug": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleDebug && cd ..",
    "apk:release": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleRelease && cd ..",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "ota:release": "node scripts/release-ota.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capgo/capacitor-updater": "^8.51.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "capacitor-tcp-socket": "^7.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.5.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
