{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MODA+ Retail",
  "version": "1.0.3",
  "identifier": "com.mrtpvrest.moda",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3012",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "cross-env CAPACITOR_BUILD=true next build"
  },
  "app": {
    "windows": [
      {
        "title": "MODA+ Retail",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4MEU5RjI2OTg1RUVGRDEKUldUUjcxNllKcDhPS0hlaDV2NXcxQTRSUEJOSUFMTURnOWgzQm1sSFZHeExWOEdRR3M1clVOVHYK",
      "endpoints": [
        "https://github.com/colonmbiano/mrtpvrest/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
