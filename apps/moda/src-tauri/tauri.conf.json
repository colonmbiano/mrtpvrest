{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MODA+ Retail",
  "version": "0.1.0",
  "identifier": "com.mrtpvrest.moda",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3012",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "cross-env CAPACITOR_BUILD=true next build"
  },
  "app": {
    "windows": [
      {
        "title": "MODA+ Retail",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
