{
  "name": "@mrtpvrest/kiosk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3007 --webpack",
    "build": "next build",
    "start": "next start -p 3007",
    "lint": "next lint",
    "build:apk": "cross-env CAPACITOR_BUILD=true next build && npx cap sync android",
    "apk:debug": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleDebug && cd ..",
    "apk:release": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleRelease && cd ..",
    "cap:open": "npx cap open android",
    "cap:sync": "npx cap sync android"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "axios": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@mrtpvrest/config": "workspace:*",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "16.2.9",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
