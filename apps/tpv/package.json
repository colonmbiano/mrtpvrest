{
  "name": "@mrtpvrest/tpv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005 --webpack",
    "build": "next build",
    "start": "next start -p 3005",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "node scripts/patch-android-plugins.js",
    "build:apk": "cross-env CAPACITOR_BUILD=true next build && npx cap sync android",
    "apk:debug": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleDebug && cd ..",
    "apk:release": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleRelease && cd ..",
    "cap:open": "npx cap open android",
    "cap:sync": "npx cap sync android",
    "ota:release": "node scripts/release-ota.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capgo/capacitor-updater": "^8.0.0",
    "capacitor-tcp-socket": "^7.1.0",
    "axios": "^1.13.6",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hotkeys-hook": "^5.2.4",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@mrtpvrest/config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "archiver": "^7.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "16.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
