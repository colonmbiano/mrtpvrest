# TPV — Variables de entorno locales
# Copia este archivo a .env.local para desarrollo local
# NO commitear .env.local al repositorio

# URL del backend (comentar la que no uses)
NEXT_PUBLIC_API_URL=https://api.mrtpvrest.com
# NEXT_PUBLIC_API_URL=http://localhost:3001     # Local backend
# NEXT_PUBLIC_API_URL=http://10.0.2.2:3001      # Android Emulator

# Nombre de la app (opcional, para branding dinámico)
NEXT_PUBLIC_APP_NAME=MRTPVREST TPV
