{
  "name": "@mrtpvrest/delivery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3006 --webpack",
    "build": "next build",
    "start": "next start -p 3006",
    "lint": "next lint",
    "build:apk": "cross-env CAPACITOR_BUILD=true next build && npx cap sync android",
    "apk:debug": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleDebug && cd ..",
    "apk:release": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat assembleRelease && cd ..",
    "aab:release": "cross-env CAPACITOR_BUILD=true pnpm run build:apk && cd android && gradlew.bat bundleRelease && cd ..",
    "cap:open": "npx cap open android",
    "cap:sync": "npx cap sync android",
    "ota:release": "node scripts/release-ota.mjs",
    "postinstall": "node scripts/patch-android-plugins.js"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@capgo/capacitor-updater": "^8.0.0",
    "axios": "^1.16.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@mrtpvrest/config": "workspace:*",
    "archiver": "^7.0.1",
    "@types/node": "^20",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "16.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
