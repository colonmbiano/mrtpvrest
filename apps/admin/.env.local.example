NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_SAAS_URL=https://saas.mrtpvrest.com

# Storefront público. En producción las tiendas se sirven por subdominio:
# https://{slug}.mrtpvrest.com  (default, no requiere setear nada).
# NEXT_PUBLIC_STORE_DOMAIN: cambia el dominio base del subdominio.
# NEXT_PUBLIC_STORE_URL: fuerza modo PATH (base/{slug}); útil en local sin wildcard DNS.
# NEXT_PUBLIC_STORE_DOMAIN=mrtpvrest.com
# NEXT_PUBLIC_STORE_URL=http://localhost:3003

# Supabase Storage (bucket público "menu-images")
# Si están vacías, el upload de imágenes cae al endpoint /api/upload/image del backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CAPTCHA anti-bot del registro (Cloudflare Turnstile). Site key (pública).
# Si está vacía, el widget no se muestra y el registro no exige token.
# Debe ir pareja con TURNSTILE_SECRET_KEY del backend.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
