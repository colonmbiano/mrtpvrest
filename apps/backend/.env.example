# ── Base de datos ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/database"

# ── JWT / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET="change-me-64-hex"
JWT_REFRESH_SECRET="change-me-64-hex"

# ── Stripe · B2B SaaS subscriptions (MRTPVREST → Tenant) ──────────────────
# Cuenta central de MRTPVREST (NO las keys del tenant para cobrar órdenes).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# URLs de retorno tras checkout / portal. Si se omiten se usa FRONTEND_URL.
# STRIPE_CHECKOUT_SUCCESS_URL=https://admin.mrtpvrest.com/billing?status=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CHECKOUT_CANCEL_URL=https://admin.mrtpvrest.com/billing?status=cancel
# STRIPE_BILLING_PORTAL_RETURN_URL=https://admin.mrtpvrest.com/billing

# ── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── MercadoPago (pagos a clientes finales, por-tenant) ─────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ── Frontend público (admin) ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3002

# ── Web Push Notifications ─────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ── Google AI (Gemini) ─────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=

# ── Resend / Correo ────────────────────────────────────────────────────────
RESEND_API_KEY=
SMTP_USER=mrtpvrest@example.com
SMTP_FROM_NAME=MRTPVREST

# ── CORS extra (coma-separado) ─────────────────────────────────────────────
# CORS_ORIGINS=https://preview-1.vercel.app,https://foo.bar
