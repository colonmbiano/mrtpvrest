# Backend de la API (público). Por defecto el storefront ya cae al backend
# canónico de producción; setéalo solo para apuntar a otro (local/staging).
NEXT_PUBLIC_API_URL=https://api.mrtpvrest.com
# Slug de la tienda por defecto (opcional; el storefront resuelve por /[slug]).
NEXT_PUBLIC_STORE_SLUG=masterburguers
